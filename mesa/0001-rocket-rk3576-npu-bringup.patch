diff --git a/src/gallium/drivers/rocket/rkt_ml.h b/src/gallium/drivers/rocket/rkt_ml.h
index 04dea3d..ced9bc0 100644
--- a/src/gallium/drivers/rocket/rkt_ml.h
+++ b/src/gallium/drivers/rocket/rkt_ml.h
@@ -11,9 +11,14 @@
 #include "rkt_device.h"
 
 // http://nvdla.org/hw/v1/ias/unit_description.html#convolution-buffer
-#define CBUF_BANK_SIZE        32768
-#define CBUF_BANKS            12
-#define CBUF_ENTRIES_PER_BANK 256
+// RK3576 CBUF geometry: 16 banks, 1 MiB total (64 KiB/bank), found by testing
+// against the board (the previous 12-bank / 384 KiB values are RK3588's and made
+// the CNA stage feature data to the wrong CBUF entries, so its executer stayed
+// PENDING and never ran). Keep the 128-byte entry width (HW atomic), so a
+// 64 KiB bank holds 512 entries.
+#define CBUF_BANK_SIZE        65536
+#define CBUF_BANKS            16
+#define CBUF_ENTRIES_PER_BANK 512
 #define CBUF_ENTRY_SIZE       (CBUF_BANK_SIZE / CBUF_ENTRIES_PER_BANK)
 #define FEATURE_ATOMIC_SIZE   16
 #define WEIGHT_ATOMIC_SIZE    32
diff --git a/src/gallium/drivers/rocket/rkt_regcmd.c b/src/gallium/drivers/rocket/rkt_regcmd.c
index be992fd..ceac2a0 100644
--- a/src/gallium/drivers/rocket/rkt_regcmd.c
+++ b/src/gallium/drivers/rocket/rkt_regcmd.c
@@ -28,6 +28,414 @@ emit(struct util_dynarray *regs, uint32_t reg, uint32_t value)
 
 #define EMIT(offset, value) emit(regs, offset, value);
 
+/*
+ * RK3576 first-convolution encoder (Phase 1).
+ *
+ * The RK3576 NPU uses a register layout that differs from the RK3588-derived map
+ * the rest of this driver emits: it has registers RK3588 lacks and the field
+ * packing at shared offsets differs. Established on hardware by sweeping one conv
+ * parameter at a time and observing which register tracks it.
+ *
+ * This emits the exact register sequence the board's working stream uses for the
+ * 224x224x3 -> 112x112x32 first convolution (the in_ch<=4 "ARGB-packed" datapath),
+ * with the five DMA-address fields patched to this run's tensor allocations:
+ *   0x1088 input feature, 0x1110 weights, 0x4018 output, 0x5020/0x5024 bias.
+ * Geometry/const/quant words are the board's known-good values for this shape.
+ * Purpose: validate the RK3576 offset map + arming + addressing end-to-end.
+ */
+static void
+fill_first_regcmd_rk3576_firstconv(struct rkt_ml_subgraph *subgraph,
+                                   const struct rkt_operation *operation,
+                                   struct util_dynarray *regs, unsigned task_num)
+{
+   struct split_task *task =
+      util_dynarray_element(&operation->tasks, struct split_task, task_num);
+
+   uint32_t feature_addr =
+      rkt_get_tensor(subgraph, operation->input_index)->phys_addr +
+      task->input_offset;
+   uint32_t weight_addr = rkt_resource(operation->weights)->phys_addr;
+   uint32_t output_addr =
+      rkt_get_tensor(subgraph, operation->output_index)->phys_addr +
+      task->output_offset;
+   uint32_t bias_addr = rkt_resource(operation->biases)->phys_addr;
+
+#define R_CNA(reg, val)  emit_raw(regs, 0x201, (reg), (val))
+#define R_CORE(reg, val) emit_raw(regs, 0x801, (reg), (val))
+#define R_DPU(reg, val)  emit_raw(regs, 0x1001, (reg), (val))
+#define R_RDMA(reg, val) emit_raw(regs, 0x2001, (reg), (val))
+
+   /* S_POINTER arming for all four units (POINTER=0, PP enabled). */
+   R_CNA(0x1004, 0x0000000e);
+   R_CORE(0x3004, 0x0000000e);
+   R_CNA(0x1038, 0x00000007);
+   R_DPU(0x4004, 0x0000000e);
+   R_RDMA(0x5004, 0x0000000e);
+
+   /* CNA config block. */
+   R_CNA(0x100c, 0x2000a006);
+   R_CNA(0x1010, 0x00000fff);
+   R_CNA(0x1014, 0x00000012);   /* stride (2,2) */
+   R_CNA(0x1018, 0x40000404);
+   R_CNA(0x101c, 0x00000600);
+   R_CNA(0x1020, 0x00000030);
+   R_CNA(0x1024, 0x0202001f);   /* out_ch-1 = 31 */
+   R_CNA(0x1028, 0x0d20000b);
+   R_CNA(0x102c, 0x00df00df);   /* (in_w-1, in_h-1) = (223,223) */
+   R_CNA(0x1030, 0x0060006f);   /* out_w-1 = 111 */
+   R_CNA(0x1034, 0x000030ff);   /* out_w*out_h-1 = 12543 */
+   R_CNA(0x1038, 0x00000007);
+   R_CNA(0x103c, 0x000f0000);
+   R_CNA(0x1040, 0x10000000);
+   R_CNA(0x1044, 0x00e0000f);   /* in_w = 224 */
+   R_CNA(0x1048, 0x000e38e0);
+   R_CNA(0x104c, 0x40004000);   /* CVT (quant) */
+   R_CNA(0x1050, 0x00014000);
+   R_CNA(0x1054, 0xffffff80);
+   R_CNA(0x1058, 0xffffff80);
+   R_CNA(0x105c, 0xffffff80);
+   R_CNA(0x1060, 0x00000000);
+   R_CNA(0x1064, 0x00000777);
+   R_CNA(0x1068, 0x00000000);
+   R_CNA(0x106c, 0x00000000);
+   R_CNA(0x1070, 0x00000000);
+   R_CNA(0x1074, 0x00000000);
+   R_CNA(0x1078, 0x002900df);
+   R_CNA(0x107c, 0x00000002);
+   R_CNA(0x1080, 0x00000101);
+   R_CNA(0x1084, 0x00808080);
+   R_CNA(0x1088, feature_addr); /* input feature base addr */
+   R_CNA(0x108c, 0x000f000f);
+   R_CNA(0x1090, 0x0000002a);   /* CBUF input line-stride = ceil(224/16)*3 */
+   R_CNA(0x1094, 0x000024c0);
+   R_CNA(0x1098, 0x000024c0);
+   R_CNA(0x109c, 0x00000000);
+   R_CNA(0x1100, 0x00000000);
+   R_CNA(0x1104, 0x00000000);
+   R_CNA(0x1110, weight_addr);  /* weights base addr (DCOMP_ADDR0) */
+   R_CNA(0x1140, 0x00000000);
+   R_CNA(0x1144, 0x00000000);
+   R_CNA(0x118c, 0x000e000d);
+
+   /* CORE. */
+   R_CORE(0x3018, 0x10000081); /* MISC/MAC cfg (first-conv in_ch=3) */
+   R_CORE(0x301c, 0x006f006f); /* (out_h-1, out_w-1) */
+   R_CORE(0x3020, 0x0000001f); /* out_ch-1 */
+   R_CORE(0x3024, 0x00000000);
+
+   /* DPU. */
+   R_DPU(0x400c, 0x40000004);
+   R_DPU(0x4010, 0x00000000);
+   R_DPU(0x4014, 0x00000000);
+   R_DPU(0x4018, output_addr); /* output (DST) base addr */
+   R_DPU(0x401c, 0x00003100); /* out_w*out_h */
+   R_DPU(0x4020, 0x0000006f); /* out_w-1 */
+   R_DPU(0x4024, 0x0000006f); /* out_h-1 */
+   R_DPU(0x4028, 0x00000000);
+   R_DPU(0x402c, 0x0000001f); /* out_ch-1 */
+   R_DPU(0x4030, 0x001f0710);
+   R_DPU(0x4034, 0x006f006f); /* (out_h-1, out_w-1) */
+   R_DPU(0x4038, 0x00120080);
+   R_DPU(0x403c, 0x00000000);
+   R_DPU(0x4044, 0x00000001);
+   R_DPU(0x4048, 0x80000000);
+   R_DPU(0x404c, 0x7fffffff);
+   R_DPU(0x4050, 0x80011111);
+   R_DPU(0x4058, 0x80000000);
+   R_DPU(0x405c, 0x7fffffff);
+   R_DPU(0x4060, 0x00000903);
+   R_DPU(0x406c, 0x80000000);
+   R_DPU(0x4070, 0x7fffffff);
+   R_DPU(0x4074, 0x80000000);
+   R_DPU(0x4078, 0x7fffffff);
+   R_DPU(0x407c, 0x010041c1);
+   R_DPU(0x4080, 0x00000000);
+   R_DPU(0x4084, 0x00000001);
+   R_DPU(0x4088, 0x80000000);
+   R_DPU(0x408c, 0x7fffffff);
+   R_DPU(0x4090, 0x00000000);
+   R_DPU(0x4094, 0x00000000);
+   R_DPU(0x409c, 0x00000000);
+   R_DPU(0x40a4, 0x80000000);
+   R_DPU(0x40a8, 0x7fffffff);
+   R_DPU(0x40ac, 0xfffffffe);
+   R_DPU(0x40b0, 0x00005391); /* OUT_CVT requant scale */
+   R_DPU(0x40b4, 0x00000019); /* OUT_CVT shift */
+   R_DPU(0x40b8, 0x00003100); /* out_w*out_h */
+   R_DPU(0x40bc, 0x00000000);
+   R_DPU(0x40c0, 0x04440100);
+   R_DPU(0x40c8, 0x00000000);
+   R_DPU(0x40cc, 0x00000000);
+   R_DPU(0x40d0, 0x0040ffff);
+   for (uint32_t r = 0x4100; r <= 0x4120; r += 4)
+      R_DPU(r, 0x00000000);
+   R_DPU(0x4130, 0x00000000);
+   for (uint32_t r = 0x4140; r <= 0x4154; r += 4)
+      R_DPU(r, 0x00000000);
+   R_DPU(0x4160, 0x00000000);
+   R_DPU(0x4170, 0x00000000);
+   R_DPU(0x4174, 0x00000000);
+   R_DPU(0x4184, 0x00000000);
+   R_DPU(0x4188, 0x00000000);
+   R_DPU(0x418c, 0x00000000);
+   R_DPU(0x4190, 0x00000000);
+   R_DPU(0x4194, 0x00000000);
+
+   /* DPU_RDMA. */
+   R_RDMA(0x500c, 0x0000006f); /* out_w-1 */
+   R_RDMA(0x5010, 0x0000006f); /* out_h-1 */
+   R_RDMA(0x5014, 0x0000001f); /* out_ch-1 */
+   R_RDMA(0x5018, 0x00000000);
+   R_RDMA(0x501c, 0x00000710);
+   R_RDMA(0x5020, bias_addr);          /* bias (BS) base addr */
+   R_RDMA(0x5024, bias_addr + 0x100);  /* bias second buffer (+0x100 per board) */
+   R_RDMA(0x5028, 0x00000000);
+   R_RDMA(0x502c, 0x00000000);
+   R_RDMA(0x5030, 0x00000000);
+   R_RDMA(0x5034, 0x00000041);
+   R_RDMA(0x5038, 0x00000000);
+   R_RDMA(0x5040, 0x00000000);
+   R_RDMA(0x5044, 0x40000010);
+   R_RDMA(0x5048, 0x00000000);
+   R_RDMA(0x504c, 0x00000000);
+   R_RDMA(0x5064, 0x00000000);
+   R_RDMA(0x506c, 0x00000000);
+   R_RDMA(0x5078, 0x00000000);
+   R_RDMA(0x507c, 0x00000000);
+
+   /* Broadcast op_en (target 0x81): start all units. Kernel also pulses PC_OP_EN. */
+   emit_raw(regs, 0x81, REG_PC_OPERATION_ENABLE, 0x1d);
+
+#undef R_CNA
+#undef R_CORE
+#undef R_DPU
+#undef R_RDMA
+}
+
+/*
+ * RK3576 general convolution encoder (Phase 2) for the in_ch>4 normal and
+ * depthwise datapaths (MobileNet's pointwise + depthwise layers).
+ *
+ * Geometry/channel/CBUF register formulas were established on hardware by
+ * sweeping one conv parameter at a time and observing which register tracks it;
+ * they reproduce the board's working register stream exactly for every shape
+ * tested. Quantisation (CNA CVT bypass + DPU OUT_CVT scale/shift/offset) uses
+ * the driver's own requant math placed at the RK3576 offsets; the five DMA
+ * addresses are patched to this run's tensors.
+ */
+static void
+fill_regcmd_rk3576_normal(struct rkt_ml_subgraph *subgraph,
+                          const struct rkt_operation *operation,
+                          struct util_dynarray *regs, unsigned task_num)
+{
+   struct split_task *task =
+      util_dynarray_element(&operation->tasks, struct split_task, task_num);
+
+   unsigned inw = task->input_width, inh = task->input_height;
+   unsigned ow = task->output_width, oh = task->output_height;
+   unsigned k = task->weights_width;
+   unsigned s = task->stride_x;
+   unsigned ic = task->input_channels;
+   unsigned oc = task->output_channels;
+   bool dw = operation->depthwise;
+
+   unsigned surf = inw * ic / 64;                /* input CBUF surface stride */
+   unsigned wbpk = dw ? (k * k * ic / 8) : (ic * k * k * 2); /* weight bytes/kernel */
+   unsigned ohh = (oh - 1) >> 1;                 /* halved output-height field */
+   unsigned k_word = (k >= 3) ? 0x0202 : 0;
+
+   /*
+    * CBUF row window: the CNA stages only `window` input rows at a time and
+    * streams. Layers up to 56 wide always fit (window = full height); only the
+    * 112-wide layers exceed the CBUF and are windowed (values measured on the
+    * board). Without this the CNA stages the full height the CBUF can't hold and
+    * stalls after one burst.
+    */
+   unsigned window = inh;
+   if (inw >= 112) {
+      if (ic <= 32)
+         window = 91;
+      else
+         window = (s >= 2) ? 44 : 45;
+      if (window > inh)
+         window = inh;
+   }
+   bool capped = window < inh;
+   unsigned owin = (window - ((dw && s == 1 && capped) ? 1 : 0)) / s;
+
+   uint32_t feature_addr =
+      rkt_get_tensor(subgraph, operation->input_index)->phys_addr +
+      task->input_offset;
+   uint32_t weight_addr = rkt_resource(operation->weights)->phys_addr;
+   uint32_t output_addr =
+      rkt_get_tensor(subgraph, operation->output_index)->phys_addr +
+      task->output_offset;
+   uint32_t bias_addr = rkt_resource(operation->biases)->phys_addr;
+
+   /* Requant (same math the legacy path uses), placed at the RK3576 offsets. */
+   float conv_scale =
+      (task->input_scale * task->weights_scale) / task->output_scale;
+   uint32_t scale_bits = fui(conv_scale);
+   unsigned shift = 127 + 31 - 32 - (scale_bits >> 23) + 16;
+   if (operation->truncate_bits > 0)
+      shift--;
+   unsigned cvt_scale = ((scale_bits >> 9) & 0x7fff) + 1;
+   if (cvt_scale < (1 << 14))
+      cvt_scale |= (1 << 14);
+   int32_t out_offset = (int32_t)task->output_zero_point - 0x80;
+
+#define R_CNA(reg, val)  emit_raw(regs, 0x201, (reg), (val))
+#define R_CORE(reg, val) emit_raw(regs, 0x801, (reg), (val))
+#define R_DPU(reg, val)  emit_raw(regs, 0x1001, (reg), (val))
+#define R_RDMA(reg, val) emit_raw(regs, 0x2001, (reg), (val))
+
+   /* arming */
+   R_CNA(0x1004, 0x0000000e);
+   R_CORE(0x3004, 0x0000000e);
+   R_CNA(0x1038, 0x00000007);
+   R_DPU(0x4004, 0x0000000e);
+   R_RDMA(0x5004, 0x0000000e);
+
+   /* CNA (verified geometry/channel formulas; CVT = bypass; quant via DPU). */
+   R_CNA(0x100c, dw ? 0x1 : 0x0);
+   R_CNA(0x1010, 0x00000fff);
+   R_CNA(0x1014, (s << 3) | s);
+   R_CNA(0x1018, capped ? 0x40000505 : 0x40000404);
+   R_CNA(0x101c, dw ? (oc * k * k * 2) : (ic * oc * k * k));
+   R_CNA(0x1020, (dw ? oc : ic) * k * k);
+   R_CNA(0x1024, (k_word << 16) | (dw ? 1 : (oc - 1)));
+   R_CNA(0x1028, ((surf * window) << 16) | (ic - 1));
+   R_CNA(0x102c, ((inw - 1) << 16) | (window - 1));
+   R_CNA(0x1030, (wbpk << 16) | (ow - 1));
+   R_CNA(0x1034, ow * owin - 1);
+   R_CNA(0x1038, 0x00000007);
+   R_CNA(0x103c, surf << 16);
+   R_CNA(0x1040, capped ? 0x14000000 : 0x10000000);
+   R_CNA(0x1044, (inw << 16) | surf);
+   R_CNA(0x1048, 0x0000000b);
+   R_CNA(0x104c, 0x00010001);   /* CVT bypass (requant is in DPU OUT_CVT) */
+   R_CNA(0x1050, 0x00010001);
+   R_CNA(0x1054, 0x00000000);
+   R_CNA(0x1058, 0x00000000);
+   R_CNA(0x105c, 0x00000000);
+   R_CNA(0x1060, 0x00000000);
+   R_CNA(0x1064, 0x00000000);
+   R_CNA(0x1068, 0x00000000);
+   R_CNA(0x106c, 0x00000000);
+   R_CNA(0x1070, 0x00000000);
+   R_CNA(0x1074, 0x00000000);
+   R_CNA(0x1078, ((inw - 1) << 16) | (window - 1));
+   R_CNA(0x107c, ic - 1);
+   R_CNA(0x1080, s == 2 ? 0x101
+                        : (dw ? (capped ? 0x01000101 : 0x01010101) : 0));
+   R_CNA(0x1084, 0xffffff80);
+   R_CNA(0x1088, feature_addr);
+   R_CNA(0x108c, 0x000f000f);
+   R_CNA(0x1090, inw * 4);
+   R_CNA(0x1094, inw * inh);
+   R_CNA(0x1098, (inw * window + 3) & ~3u);
+   R_CNA(0x109c, 0x00000000);
+   R_CNA(0x1100, 0x00000000);
+   R_CNA(0x1104, 0x00000000);
+   R_CNA(0x1110, weight_addr);
+   R_CNA(0x1140, 0x00000000);
+   R_CNA(0x1144, 0x00000000);
+   R_CNA(0x118c, ((inw - 1) << 16) | (inh - 1));
+
+   /* CORE */
+   R_CORE(0x3018, 0x10000000 | (dw ? 0x0a : 0x01));
+   R_CORE(0x301c, (ohh << 16) | (ow - 1));
+   R_CORE(0x3020, oc - 1);
+   R_CORE(0x3024, 0x00000000);
+
+   /* DPU */
+   R_DPU(0x400c, 0x40000004 | (dw ? 0x08 : 0));
+   R_DPU(0x4010, 0x00000000);
+   R_DPU(0x4014, 0x00000000);
+   R_DPU(0x4018, output_addr);
+   R_DPU(0x401c, ow * oh);
+   R_DPU(0x4020, ow - 1);
+   R_DPU(0x4024, ohh);
+   R_DPU(0x4028, 0x00000000);
+   R_DPU(0x402c, oc - 1);
+   R_DPU(0x4030, ((oc - 1) << 16) | (dw ? 0x0310 : 0x0710));
+   R_DPU(0x4034, (ohh << 16) | (ow - 1));
+   R_DPU(0x4038, dw ? 0x00100092 : 0x00120080);
+   R_DPU(0x403c, 0x00000000);
+   R_DPU(0x4044, dw ? 0x00000000 : 0x00000001);
+   R_DPU(0x4048, 0x80000000);
+   R_DPU(0x404c, 0x7fffffff);
+   R_DPU(0x4050, dw ? 0x00013133 : 0x80011111);
+   R_DPU(0x4058, 0x80000000);
+   R_DPU(0x405c, 0x7fffffff);
+   R_DPU(0x4060, 0x00000903);
+   R_DPU(0x406c, 0x80000000);
+   R_DPU(0x4070, 0x7fffffff);
+   R_DPU(0x4074, 0x80000000);
+   R_DPU(0x4078, 0x7fffffff);
+   R_DPU(0x407c, 0x010041c1);
+   R_DPU(0x4080, 0x00000000);
+   R_DPU(0x4084, 0x00000001);
+   R_DPU(0x4088, 0x80000000);
+   R_DPU(0x408c, 0x7fffffff);
+   R_DPU(0x4090, 0x00000000);
+   R_DPU(0x4094, 0x00000000);
+   R_DPU(0x409c, 0x00000000);
+   R_DPU(0x40a4, 0x80000000);
+   R_DPU(0x40a8, 0x7fffffff);
+   R_DPU(0x40ac, (uint32_t)out_offset);          /* OUT_CVT offset */
+   R_DPU(0x40b0, cvt_scale);                      /* OUT_CVT scale */
+   R_DPU(0x40b4, shift - 1);                      /* OUT_CVT shift */
+   R_DPU(0x40b8, dw ? (ow * oh * 7 / 2) : (ow * oh * 3 / 2));
+   R_DPU(0x40bc, 0x00000000);
+   R_DPU(0x40c0, 0x04440100);
+   R_DPU(0x40c8, 0x00000000);
+   R_DPU(0x40cc, 0x00000000);
+   R_DPU(0x40d0, 0x0040ffff);
+   for (uint32_t r = 0x4100; r <= 0x4120; r += 4)
+      R_DPU(r, 0x00000000);
+   R_DPU(0x4130, 0x00000000);
+   for (uint32_t r = 0x4140; r <= 0x4154; r += 4)
+      R_DPU(r, 0x00000000);
+   R_DPU(0x4160, 0x00000000);
+   R_DPU(0x4170, 0x00000000);
+   R_DPU(0x4174, 0x00000000);
+   R_DPU(0x4184, 0x00000000);
+   R_DPU(0x4188, 0x00000000);
+   R_DPU(0x418c, 0x00000000);
+   R_DPU(0x4190, 0x00000000);
+   R_DPU(0x4194, 0x00000000);
+
+   /* DPU_RDMA */
+   R_RDMA(0x500c, ow - 1);
+   R_RDMA(0x5010, ohh);
+   R_RDMA(0x5014, oc - 1);
