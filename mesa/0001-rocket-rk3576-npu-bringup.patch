+   R_DPU(0x4028, 0x00000000);
+   R_DPU(0x402c, 0x0000001f); /* out_ch-1 */
+   R_DPU(0x4030, 0x001f0710);
+   R_DPU(0x4034, 0x006f006f); /* (out_h-1, out_w-1) */
+   R_DPU(0x4038, 0x00120080);
+   R_DPU(0x403c, 0x00000000);
+   R_DPU(0x4044, 0x00000001);
+   R_DPU(0x4048, 0x80000000);
+   R_DPU(0x404c, 0x7fffffff);
+   R_DPU(0x4050, 0x80011111);
+   R_DPU(0x4058, 0x80000000);
+   R_DPU(0x405c, 0x7fffffff);
+   R_DPU(0x4060, 0x00000903);
+   R_DPU(0x406c, 0x80000000);
+   R_DPU(0x4070, 0x7fffffff);
+   R_DPU(0x4074, 0x80000000);
+   R_DPU(0x4078, 0x7fffffff);
+   R_DPU(0x407c, 0x010041c1);
+   R_DPU(0x4080, 0x00000000);
+   R_DPU(0x4084, 0x00000001);
+   R_DPU(0x4088, 0x80000000);
+   R_DPU(0x408c, 0x7fffffff);
+   R_DPU(0x4090, 0x00000000);
+   R_DPU(0x4094, 0x00000000);
+   R_DPU(0x409c, 0x00000000);
+   R_DPU(0x40a4, 0x80000000);
+   R_DPU(0x40a8, 0x7fffffff);
+   /*
+    * OUT_CVT requant from THIS conv's real scales. The previously hardcoded
+    * 0xfffffffe/0x5391/0x19 were captured from a different (random-weight)
+    * first conv, so they saturated MobileNet's conv0 output to the ReLU6
+    * extremes and every downstream layer then clamped. Compute it the same way
+    * the normal encoder does.
+    */
+   {
+      float fc_conv_scale =
+         (task->input_scale * task->weights_scale) / task->output_scale;
+      uint32_t fc_scale_bits = fui(fc_conv_scale);
+      unsigned fc_shift = 127 + 31 - 32 - (fc_scale_bits >> 23) + 16;
+      unsigned fc_cvt_scale = ((fc_scale_bits >> 9) & 0x7fff) + 1;
+
+      if (operation->truncate_bits > 0)
+         fc_shift--;
+      if (fc_cvt_scale < (1 << 14))
+         fc_cvt_scale |= (1 << 14);
+
+      R_DPU(0x40ac, (uint32_t)((int32_t)task->output_zero_point - 0x80));
+      R_DPU(0x40b0, fc_cvt_scale);   /* OUT_CVT requant scale */
+      R_DPU(0x40b4, fc_shift - 1);   /* OUT_CVT shift */
+   }
+   R_DPU(0x40b8, 0x00003100); /* out_w*out_h */
+   R_DPU(0x40bc, 0x00000000);
+   R_DPU(0x40c0, 0x04440100);
+   R_DPU(0x40c8, 0x00000000);
+   R_DPU(0x40cc, 0x00000000);
+   R_DPU(0x40d0, 0x0040ffff);
+   for (uint32_t r = 0x4100; r <= 0x4120; r += 4)
+      R_DPU(r, 0x00000000);
+   R_DPU(0x4130, 0x00000000);
+   for (uint32_t r = 0x4140; r <= 0x4154; r += 4)
+      R_DPU(r, 0x00000000);
+   R_DPU(0x4160, 0x00000000);
+   R_DPU(0x4170, 0x00000000);
+   R_DPU(0x4174, 0x00000000);
+   R_DPU(0x4184, 0x00000000);
+   R_DPU(0x4188, 0x00000000);
+   R_DPU(0x418c, 0x00000000);
+   R_DPU(0x4190, 0x00000000);
+   R_DPU(0x4194, 0x00000000);
+
+   /* DPU_RDMA. */
+   R_RDMA(0x500c, 0x0000006f); /* out_w-1 */
+   R_RDMA(0x5010, 0x0000006f); /* out_h-1 */
+   R_RDMA(0x5014, 0x0000001f); /* out_ch-1 */
+   R_RDMA(0x5018, 0x00000000);
+   R_RDMA(0x501c, 0x00000710);
+   R_RDMA(0x5020, bias_addr);          /* bias (BS) base addr */
+   R_RDMA(0x5024, bias_addr + 0x100);  /* bias second buffer (+0x100 per board) */
+   R_RDMA(0x5028, 0x00000000);
+   R_RDMA(0x502c, 0x00000000);
+   R_RDMA(0x5030, 0x00000000);
+   R_RDMA(0x5034, 0x00000041);
+   R_RDMA(0x5038, 0x00000000);
+   R_RDMA(0x5040, 0x00000000);
+   R_RDMA(0x5044, 0x40000010);
+   R_RDMA(0x5048, 0x00000000);
+   R_RDMA(0x504c, 0x00000000);
+   R_RDMA(0x5064, 0x00000000);
+   R_RDMA(0x506c, 0x00000000);
+   R_RDMA(0x5078, 0x00000000);
+   R_RDMA(0x507c, 0x00000000);
+
+   /* Broadcast op_en (target 0x81): start all units. Kernel also pulses PC_OP_EN. */
+   emit_raw(regs, 0x81, REG_PC_OPERATION_ENABLE, 0x1d);
+
+#undef R_CNA
+#undef R_CORE
+#undef R_DPU
+#undef R_RDMA
+}
