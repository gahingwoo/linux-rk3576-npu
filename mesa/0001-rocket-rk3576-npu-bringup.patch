+/*
+ * Detect the SoC behind the rocket DRM device. The rocket uAPI has no version/
+ * param query, so read the platform device's OF "compatible" via sysfs (the
+ * NVDLA-derived NPUs differ by register map + CBUF geometry). ROCKET_SOC=rk3576|
+ * rk3588 overrides. Defaults to RK3576 (this tree's primary target) when the
+ * compatible can't be read.
+ */
+static enum rkt_soc
+rkt_detect_soc(int fd)
+{
+   const char *override = getenv("ROCKET_SOC");
+   if (override) {
+      if (strstr(override, "3588"))
+         return RKT_SOC_RK3588;
+      if (strstr(override, "3576"))
+         return RKT_SOC_RK3576;
+   }
+
+   struct stat st;
+   if (fstat(fd, &st) == 0 && S_ISCHR(st.st_mode)) {
+      char path[128], buf[512];
+      snprintf(path, sizeof(path),
+               "/sys/dev/char/%u:%u/device/of_node/compatible",
+               major(st.st_rdev), minor(st.st_rdev));
+      FILE *f = fopen(path, "r");
+      if (f) {
+         size_t n = fread(buf, 1, sizeof(buf) - 1, f);
+         fclose(f);
+         buf[n] = '\0';
+         /* compatible is a NUL-separated list; scan the whole blob. */
+         for (size_t i = 0; i < n; i++) {
+            if (!strncmp(buf + i, "rk3588", 6) || !strncmp(buf + i, "rk3568", 6))
+               return RKT_SOC_RK3588;
+            if (!strncmp(buf + i, "rk3576", 6))
+               return RKT_SOC_RK3576;
+         }
+      }
+   }
+
+   return RKT_SOC_RK3576;
+}
