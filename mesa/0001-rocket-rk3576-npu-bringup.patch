+/*
+ * RK3576 general convolution encoder (Phase 2) for the in_ch>4 normal and
+ * depthwise datapaths (MobileNet's pointwise + depthwise layers).
+ *
+ * Geometry/channel/CBUF register formulas were established on hardware by
+ * sweeping one conv parameter at a time and observing which register tracks it;
+ * they reproduce the board's working register stream exactly for every shape
+ * tested. Quantisation (CNA CVT bypass + DPU OUT_CVT scale/shift/offset) uses
+ * the driver's own requant math placed at the RK3576 offsets; the five DMA
+ * addresses are patched to this run's tensors.
+ */
+static void
+fill_regcmd_rk3576_normal(struct rkt_ml_subgraph *subgraph,
+                          const struct rkt_operation *operation,
+                          struct util_dynarray *regs, unsigned task_num)
+{
+   struct split_task *task =
+      util_dynarray_element(&operation->tasks, struct split_task, task_num);
+
+   unsigned inw = task->input_width;
+   unsigned ow = task->output_width;
+   unsigned k = task->weights_width;
+   unsigned s = task->stride_x;
+   /*
+    * The RK3576 register stream uses the REAL channel counts, not fill_task's
+    * CBUF-aligned ones (which double the depthwise channels and round others up
+    * to 32). Using the aligned values emits e.g. out_ch-1 = 63 instead of 31 for
+    * a 32-channel depthwise layer.
+    */
+   unsigned ic = task->input_channels_real;
+   unsigned oc = task->output_channels_real;
+   bool dw = operation->depthwise;
+
+   /*
+    * The 112-wide in_ch>4 layers are dispatched as multiple row-window tasks
+    * (see rkt_split_tasks): each task produces win_orows output rows from
+    * win_irows staged input rows. A non-windowed layer is a single task whose
+    * window equals the full layer.
+    */
+   unsigned full_inh = operation->input_height;
+   unsigned full_oh = operation->output_height;
+   unsigned win_orows = task->output_height;   /* this window's output rows */
+   unsigned win_irows = task->input_height;     /* this window's staged input rows */
+   bool capped = win_orows < full_oh;           /* a window of a larger output */
+   unsigned wnum = task->num;
+
+   unsigned surf = inw * ic / 64;                /* input CBUF surface stride */
+   unsigned wbpk = dw ? (k * k * ic / 8) : (ic * k * k * 2); /* weight bytes/kernel */
+   unsigned k_word = (k >= 3) ? 0x0202 : 0;
+   uint32_t reuse = (capped && wnum > 0) ? 0x1800 : 0;  /* DATA_REUSE overlap rows */
+
+   /*
+    * DPU/CORE output-height field: non-windowed layers pack two output rows per
+    * surface line ((oh-1)>>1); windowed layers emit one line per output row of
+    * the window (win_orows-1), matching how the windowed CNA feeds the DPU.
+    */
+   unsigned dpu_lines = capped ? (win_orows - 1) : ((full_oh - 1) >> 1);
+
+   uint32_t feature_addr =
+      rkt_get_tensor(subgraph, operation->input_index)->phys_addr +
+      task->input_offset;
+   uint32_t weight_addr = rkt_resource(operation->weights)->phys_addr;
+   uint32_t output_addr =
+      rkt_get_tensor(subgraph, operation->output_index)->phys_addr +
+      task->output_offset;
+   uint32_t bias_addr = rkt_resource(operation->biases)->phys_addr;
+
+   /* Requant (same math the legacy path uses), placed at the RK3576 offsets. */
+   float conv_scale =
+      (task->input_scale * task->weights_scale) / task->output_scale;
+   uint32_t scale_bits = fui(conv_scale);
+   unsigned shift = 127 + 31 - 32 - (scale_bits >> 23) + 16;
+   if (operation->truncate_bits > 0)
+      shift--;
+   unsigned cvt_scale = ((scale_bits >> 9) & 0x7fff) + 1;
+   if (cvt_scale < (1 << 14))
+      cvt_scale |= (1 << 14);
+   int32_t out_offset = (int32_t)task->output_zero_point - 0x80;
+
+#define R_CNA(reg, val)  emit_raw(regs, 0x201, (reg), (val))
+#define R_CORE(reg, val) emit_raw(regs, 0x801, (reg), (val))
+#define R_DPU(reg, val)  emit_raw(regs, 0x1001, (reg), (val))
+#define R_RDMA(reg, val) emit_raw(regs, 0x2001, (reg), (val))
+
+   /*
+    * Arm S_POINTER for all four units at the very start of every task, the way
+    * the vendor's per-task command stream does: POINTER=0 with the ping-pong
+    * enables set (0x0e).  The vendor does NOT alternate ping-pong groups between
+    * tasks -- it re-points the producer at group 0 each task and writes the
+    * geometry there, so the executer reads what was just written.  Leaving this
+    * to the kernel (and alternating the pointer per task) made the geometry land
+    * in a group the DPU/CORE never read, so they executed on an uninitialised
+    * group: the units engaged but the DPU wrote nothing (garbage cube, DST read
+    * back as the width field) and every layer after the first produced zeros.
+    */
+   R_CNA(0x1004, 0x0000000e);
+   R_CORE(0x3004, 0x0000000e);
+   R_CNA(0x1038, 0x00000007);
+   R_DPU(0x4004, 0x0000000e);
+   R_RDMA(0x5004, 0x0000000e);
+
+   /* CNA (verified geometry/channel formulas; CVT = bypass; quant via DPU). */
+   R_CNA(0x100c, dw ? 0x1 : 0x0);
+   R_CNA(0x1010, 0x00000fff);
+   R_CNA(0x1014, ((s << 3) | s) | (capped ? 0x10000000 : 0));
+   R_CNA(0x1018, capped ? (wnum > 0 ? 0x4000060c : 0x40000606) : 0x40000505);
+   R_CNA(0x101c, dw ? (oc * k * k * 2) : (ic * oc * k * k));
+   R_CNA(0x1020, (dw ? oc : ic) * k * k);
+   R_CNA(0x1024, (k_word << 16) | (dw ? 1 : (oc - 1)));
+   R_CNA(0x1028, ((surf * win_irows) << 16) | (ic - 1));
+   R_CNA(0x102c, ((inw - 1) << 16) | (win_irows - 1));
+   R_CNA(0x1030, (wbpk << 16) | (ow - 1));
+   R_CNA(0x1034, ow * win_orows - 1);
+   R_CNA(0x1038, capped ? (wnum > 0 ? 0x80000010 : 0x10) : 0x07);
+   R_CNA(0x103c, (surf << 16) | reuse);
+   R_CNA(0x1040, capped ? (0x30000000 | reuse) : 0x14000000);
+   R_CNA(0x1044, (inw << 16) | surf);
+   R_CNA(0x1048, 0x0000000b);
+   R_CNA(0x104c, 0x00010001);   /* CVT bypass (requant is in DPU OUT_CVT) */
+   R_CNA(0x1050, 0x00010001);
+   R_CNA(0x1054, 0x00000000);
+   R_CNA(0x1058, 0x00000000);
+   R_CNA(0x105c, 0x00000000);
+   R_CNA(0x1060, 0x00000000);
+   R_CNA(0x1064, 0x00000000);
+   R_CNA(0x1068, 0x00000000);
+   R_CNA(0x106c, 0x00000000);
+   R_CNA(0x1070, 0x00000000);
+   R_CNA(0x1074, 0x00000000);
+   R_CNA(0x1078, ((inw - 1) << 16) | (win_irows - 1));
+   R_CNA(0x107c, ic - 1);
+   R_CNA(0x1080, s == 2 ? 0x101
+                        : (dw ? (capped ? (wnum > 0 ? 0x01010100 : 0x01000101)
+                                        : 0x01010101)
+                              : 0));
+   R_CNA(0x1084, 0xffffff80);
+   R_CNA(0x1088, feature_addr);
+   R_CNA(0x108c, 0x000f000f);
+   R_CNA(0x1090, inw * 4);
+   R_CNA(0x1094, inw * full_inh);
+   R_CNA(0x1098, (inw * win_irows + 3) & ~3u);
+   R_CNA(0x109c, 0x00000000);
+   R_CNA(0x1100, 0x00000000);
+   R_CNA(0x1104, 0x00000000);
+   R_CNA(0x1110, weight_addr);
+   R_CNA(0x1140, 0x00000000);
+   R_CNA(0x1144, 0x00000000);
+   R_CNA(0x118c, ((inw - 1) << 16) | (full_inh - 1));
+
+   /* CORE */
+   R_CORE(0x3018, 0x10000000 | (dw ? 0x0a : 0x01));
+   R_CORE(0x301c, (dpu_lines << 16) | (ow - 1));
+   R_CORE(0x3020, oc - 1);
+   R_CORE(0x3024, 0x00000000);
+
+   /* DPU */
+   R_DPU(0x400c, 0x40000004 | (dw ? 0x08 : 0));
+   R_DPU(0x4010, 0x00000000);
+   R_DPU(0x4014, 0x00000000);
+   R_DPU(0x4018, output_addr);
+   R_DPU(0x401c, ow * full_oh);
+   R_DPU(0x4020, ow - 1);
+   R_DPU(0x4024, dpu_lines);
+   R_DPU(0x4028, 0x00000000);
+   R_DPU(0x402c, oc - 1);
+   R_DPU(0x4030, ((oc - 1) << 16) | (dw ? 0x0310 : 0x0710));
+   R_DPU(0x4034, (dpu_lines << 16) | (ow - 1));
+   R_DPU(0x4038, dw ? 0x00100092 : 0x00120080);
+   R_DPU(0x403c, 0x00000000);
+   R_DPU(0x4044, dw ? 0x00000000 : 0x00000001);
+   R_DPU(0x4048, 0x80000000);
+   R_DPU(0x404c, 0x7fffffff);
+   R_DPU(0x4050, dw ? 0x00013133 : 0x80011111);
+   R_DPU(0x4058, 0x80000000);
+   R_DPU(0x405c, 0x7fffffff);
+   R_DPU(0x4060, 0x00000903);
+   R_DPU(0x406c, 0x80000000);
+   R_DPU(0x4070, 0x7fffffff);
+   R_DPU(0x4074, 0x80000000);
+   R_DPU(0x4078, 0x7fffffff);
+   R_DPU(0x407c, 0x010041c1);
+   R_DPU(0x4080, 0x00000000);
+   R_DPU(0x4084, 0x00000001);
+   R_DPU(0x4088, 0x80000000);
+   R_DPU(0x408c, 0x7fffffff);
+   R_DPU(0x4090, 0x00000000);
+   R_DPU(0x4094, 0x00000000);
+   R_DPU(0x409c, 0x00000000);
+   R_DPU(0x40a4, 0x80000000);
+   R_DPU(0x40a8, 0x7fffffff);
+   R_DPU(0x40ac, (uint32_t)out_offset);          /* OUT_CVT offset */
+   R_DPU(0x40b0, cvt_scale);                      /* OUT_CVT scale */
+   R_DPU(0x40b4, shift - 1);                      /* OUT_CVT shift */
+   R_DPU(0x40b8, capped ? ow * ((dw ? 3 : 1) * full_oh + win_orows)
+                        : ow * full_oh * (dw ? 3 : 1));
+   R_DPU(0x40bc, 0x00000000);
+   R_DPU(0x40c0, 0x04440100);
+   R_DPU(0x40c8, 0x00000000);
+   R_DPU(0x40cc, 0x00000000);
+   R_DPU(0x40d0, 0x0040ffff);
+   for (uint32_t r = 0x4100; r <= 0x4120; r += 4)
+      R_DPU(r, 0x00000000);
+   R_DPU(0x4130, 0x00000000);
+   for (uint32_t r = 0x4140; r <= 0x4154; r += 4)
+      R_DPU(r, 0x00000000);
+   R_DPU(0x4160, 0x00000000);
+   R_DPU(0x4170, 0x00000000);
+   R_DPU(0x4174, 0x00000000);
+   R_DPU(0x4184, 0x00000000);
+   R_DPU(0x4188, 0x00000000);
+   R_DPU(0x418c, 0x00000000);
+   R_DPU(0x4190, 0x00000000);
+   R_DPU(0x4194, 0x00000000);
+
+   /* DPU_RDMA */
+   R_RDMA(0x500c, ow - 1);
+   R_RDMA(0x5010, dpu_lines);
+   R_RDMA(0x5014, oc - 1);
+   R_RDMA(0x5018, 0x00000000);
+   R_RDMA(0x501c, dw ? 0x0510 : 0x0710);
+   R_RDMA(0x5020, bias_addr);
+   /* Second SDP operand points just past the [A|B|C] bias structure
+    * (DIV_ROUND_UP(oc,8)*64 bytes); it lands in the zeroed pad of the bias bo. */
+   R_RDMA(0x5024, bias_addr + DIV_ROUND_UP(oc, 8) * 64);
+   R_RDMA(0x5028, 0x00000000);
+   R_RDMA(0x502c, 0x00000000);
+   R_RDMA(0x5030, 0x00000000);
+   R_RDMA(0x5034, 0x00000041);
+   R_RDMA(0x5038, 0x00000000);
+   R_RDMA(0x5040, 0x00000000);
+   R_RDMA(0x5044, dw ? 0x40000012 : 0x40000010);
+   R_RDMA(0x5048, 0x00000000);
+   R_RDMA(0x504c, 0x00000000);
+   R_RDMA(0x5064, 0x00000000);
+   R_RDMA(0x506c, 0x00000000);
+   R_RDMA(0x5078, 0x00000000);
+   R_RDMA(0x507c, 0x00000000);
+
+   emit_raw(regs, 0x81, REG_PC_OPERATION_ENABLE, 0x1d);
+
+#undef R_CNA
+#undef R_CORE
+#undef R_DPU
+#undef R_RDMA
+}
