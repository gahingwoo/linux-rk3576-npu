+      rkt_get_tensor(subgraph, operation->input_index)->phys_addr +
+      task->input_offset;
+   uint32_t weight_addr = rkt_resource(operation->weights)->phys_addr;
+   uint32_t output_addr =
+      rkt_get_tensor(subgraph, operation->output_index)->phys_addr +
+      task->output_offset;
+   uint32_t bias_addr = rkt_resource(operation->biases)->phys_addr;
