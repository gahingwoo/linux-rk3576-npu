+	core->pp_task_idx++;
+
+	{
+		rocket_cna_writel(core, S_POINTER, CNA_S_POINTER_POINTER(pp_pointer) |
+						   CNA_S_POINTER_POINTER_PP_EN(1) |
+						   CNA_S_POINTER_EXECUTER_PP_EN(1) |
+						   CNA_S_POINTER_POINTER_PP_MODE(1) |
+						   extra_bit);
+
+		rocket_core_writel(core, S_POINTER, CORE_S_POINTER_POINTER(pp_pointer) |
+						    CORE_S_POINTER_POINTER_PP_EN(1) |
+						    CORE_S_POINTER_EXECUTER_PP_EN(1) |
+						    CORE_S_POINTER_POINTER_PP_MODE(1) |
+						    extra_bit);
+	}
+
+	dev_info(core->dev, "rocket dbg submit: CNA_SPTR=0x%08x CORE_SPTR=0x%08x DPU_SPTR=0x%08x RDMA_SPTR=0x%08x\n",
+		 rocket_cna_readl(core, S_POINTER),
+		 rocket_core_readl(core, S_POINTER),
