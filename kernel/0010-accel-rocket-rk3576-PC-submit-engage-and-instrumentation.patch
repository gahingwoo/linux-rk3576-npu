+	/*
+	 * Per-job S_POINTER arming, EXACTLY matching the vendor commit path
+	 * (rknpu_job_subcore_commit_pc): it writes S_POINTER=0x0e to CNA (0x1004)
+	 * and CORE (0x3004) only, and leaves DPU/DPU_RDMA to the in-regcmd
