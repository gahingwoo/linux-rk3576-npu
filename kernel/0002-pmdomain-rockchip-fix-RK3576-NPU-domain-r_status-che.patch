From f04e8bddf796dfa23bbf51c75e4e3d47f1474a35 Mon Sep 17 00:00:00 2001
From: gahingwoo <huhuvmb88@outlook.com>
Date: Tue, 9 Jun 2026 18:15:13 +1200
Subject: [PATCH 2/4] pmdomain/rockchip: fix RK3576 NPU domain r_status checks
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

NPUTOP, NPU0, and NPU1 are defined with r_status = BIT(22/23/24),
mapping to repair_status (PMU 0x570) and mem_status (PMU 0x250).
These bits do not reflect the actual power state on RK3576 hardware —
they never assert, causing the power-on poll to time out and the
mem_reset path to fail with:

  failed to get chain status 'nputop', target_on=1, val=0

Set r_status = 0 for these three domains so that power state is
inferred from bus-idle bits (idle_offset 0x128), which correctly
track domain activity on RK3576.  This is consistent with PD_NPU
(the parent domain), which already carries r_status = 0.

Signed-off-by: Jiaxing Hu <huhuvmb88@gmail.com>
---
 drivers/pmdomain/rockchip/pm-domains.c | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/drivers/pmdomain/rockchip/pm-domains.c b/drivers/pmdomain/rockchip/pm-domains.c
index 490bbb1d1..59fcd7a29 100644
--- a/drivers/pmdomain/rockchip/pm-domains.c
+++ b/drivers/pmdomain/rockchip/pm-domains.c
@@ -1301,9 +1301,9 @@ static const struct rockchip_domain_info rk3576_pm_domains[] = {
 	[RK3576_PD_VEPU1]	= DOMAIN_RK3576("vepu1",  0x4, BIT(3),  0,      BIT(19), 0x0, BIT(8),  BIT(8),  BIT(8),  false),
 	[RK3576_PD_VDEC]	= DOMAIN_RK3576("vdec",   0x4, BIT(4),  0,      BIT(20), 0x0, BIT(6),  BIT(6),  BIT(6),  false),
 	[RK3576_PD_VPU]		= DOMAIN_RK3576("vpu",    0x4, BIT(5),  0,      BIT(21), 0x0, BIT(5),  BIT(5),  BIT(5),  false),
-	[RK3576_PD_NPUTOP]	= DOMAIN_RK3576("nputop", 0x4, BIT(6),  0,      BIT(22), 0x0, 0x18,    0x18,    0x18,    false),
-	[RK3576_PD_NPU0]	= DOMAIN_RK3576("npu0",   0x4, BIT(7),  0,      BIT(23), 0x0, BIT(1),  BIT(1),  0x1a,    false),
-	[RK3576_PD_NPU1]	= DOMAIN_RK3576("npu1",   0x4, BIT(8),  0,      BIT(24), 0x0, BIT(2),  BIT(2),  0x1c,    false),
+	[RK3576_PD_NPUTOP]	= DOMAIN_RK3576("nputop", 0x4, BIT(6),  0,      0,       0x0, 0x18,    0x18,    0x18,    false),
+	[RK3576_PD_NPU0]	= DOMAIN_RK3576("npu0",   0x4, BIT(7),  0,      0,       0x0, BIT(1),  BIT(1),  0x1a,    false),
+	[RK3576_PD_NPU1]	= DOMAIN_RK3576("npu1",   0x4, BIT(8),  0,      0,       0x0, BIT(2),  BIT(2),  0x1c,    false),
 	[RK3576_PD_GPU]		= DOMAIN_RK3576("gpu",    0x4, BIT(9),  0,      BIT(25), 0x0, BIT(0),  BIT(0),  BIT(0),  false),
 };
 
