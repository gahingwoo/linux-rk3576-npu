 /*
  * Facade device, used to expose a single DRM device to userspace, that
  * schedules jobs to any RKNN cores in the system.
@@ -275,7 +289,10 @@ static int rocket_device_runtime_resume(struct device *dev)
 	 * reset the CNA streams the full feature+weights from DRAM but the CMAC
 	 * reads zero out of an uninitialised CBUF (conv output = zero-point).
 	 */
