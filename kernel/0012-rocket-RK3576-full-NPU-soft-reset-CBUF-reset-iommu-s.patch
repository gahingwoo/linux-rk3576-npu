+#include <linux/mm.h>
 #include <linux/platform_device.h>
 #include <linux/pm_runtime.h>
 
@@ -24,7 +28,12 @@
 #define JOB_TIMEOUT_MS 500
 
 /* ---- one-shot regcmd dump for DPU debug --------------------------------- */
-static atomic_t regcmd_dump_done = ATOMIC_INIT(0);
+/*
+ * Each inference task is a separate DRM job (task_count=1, next_task_idx=0
+ * always), so a per-job guard never fires.  Use a module-level counter to
+ * dump only the first two jobs across all submissions.
+ */
+static atomic_t regcmd_dump_job_count = ATOMIC_INIT(0);
 
 static void dump_regcmd_dpu(struct rocket_core *core, struct rocket_job *job)
 {
@@ -33,9 +42,7 @@ static void dump_regcmd_dpu(struct rocket_core *core, struct rocket_job *job)
 	void __iomem *vaddr;
 	size_t size;
 	u32 i;
-
-	if (atomic_xchg(&regcmd_dump_done, 1))
-		return;
+	int count;
 
 	task = &job->tasks[job->next_task_idx];
 	size = task->regcmd_count * sizeof(u64);
@@ -47,6 +54,34 @@ static void dump_regcmd_dpu(struct rocket_core *core, struct rocket_job *job)
 		return;
 	}
 
+	count = atomic_inc_return(&regcmd_dump_job_count);
+
+	/*
+	 * Compact FDA+DST for every job — reads entries [37] (CNA FDA) and
+	 * [77] (DPU DST) via the kernel linear map (phys_to_virt) without
+	 * the overhead of ioremap.  Shmem pages are lowmem on RK3576, so
+	 * pfn_valid + phys_to_virt is safe.  The regcmd was DMA_TO_DEVICE
+	 * mapped (CPU writes, NPU reads), so cache was cleaned before DMA;
+	 * reading through the linear map gives the same data.
+	 *
+	 * Indices updated after PP_CLEAR was moved from the start of the
+	 * regcmd to the end (Mesa fix for the 1-task PP delay): entries
+	 * shifted by -4, so old [41]/[81] become [37]/[77].
+	 */
+	if (task->regcmd_count >= 78 && pfn_valid(PFN_DOWN(phys))) {
+		const u64 *rv = (const u64 *)phys_to_virt(phys);
+		u32 fda = (u32)((rv[37] >> 16) & 0xffffffffu);
+		u32 dst = (u32)((rv[77] >> 16) & 0xffffffffu);
+
+		dev_info(core->dev,
+			 "rocket dbg regcmd[%d]: count=%u fda=0x%08x dst=0x%08x\n",
+			 count, task->regcmd_count, fda, dst);
+	}
+
+	/* Full entry-by-entry dump for the first two jobs only. */
+	if (count > 2)
+		return;
+
