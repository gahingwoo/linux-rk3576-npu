index 21223cc63..b40801479 100644
--- a/drivers/accel/rocket/rocket_gem.c
+++ b/drivers/accel/rocket/rocket_gem.c
@@ -6,7 +6,9 @@
 #include <drm/drm_utils.h>
 #include <drm/rocket_accel.h>
 #include <linux/dma-mapping.h>
+#include <linux/io.h>
 #include <linux/iommu.h>
+#include <linux/iosys-map.h>
 
 #include "rocket_drv.h"
 #include "rocket_gem.h"
@@ -138,6 +140,7 @@ int rocket_ioctl_prep_bo(struct drm_device *dev, void *data, struct drm_file *fi
 {
 	struct drm_rocket_prep_bo *args = data;
 	unsigned long timeout = drm_timeout_abs_to_jiffies(args->timeout_ns);
+	struct rocket_gem_object *rkt_obj;
 	struct drm_gem_object *gem_obj;
 	struct drm_gem_shmem_object *shmem_obj;
 	long ret = 0;
@@ -157,10 +160,45 @@ int rocket_ioctl_prep_bo(struct drm_device *dev, void *data, struct drm_file *fi
 	else if (ret > 0)
 		ret = 0;
 
-	shmem_obj = &to_rocket_bo(gem_obj)->base;
+	rkt_obj = to_rocket_bo(gem_obj);
+	shmem_obj = &rkt_obj->base;
 
 	dma_sync_sgtable_for_cpu(dev->dev, shmem_obj->sgt, DMA_BIDIRECTIONAL);
 
+	/*
+	 * Dual-path diagnostic: read the first four words via both the
+	 * CPU-cache path (page_address) and a write-combining mapping
+	 * (memremap MEMREMAP_WC) that bypasses the CPU cache and reads
+	 * directly from DRAM.
+	 *
+	 * Interpretation:
+	 *   cached==wc==0      → NPU wrote zeros (or never wrote); computation
+	 *                        bug or 1-task PP delay — last task never ran.
+	 *   cached==0, wc!=0   → NPU wrote correctly but dma_sync did not
+	 *                        invalidate the CPU cache; cache-sync bug.
+	 *   cached==wc!=0      → data is correct end-to-end; look elsewhere.
+	 */
+	if (shmem_obj->pages && shmem_obj->pages[0]) {
+		phys_addr_t phys   = page_to_phys(shmem_obj->pages[0]);
+		const u32  *cached = page_address(shmem_obj->pages[0]);
+		const u32  *wc     = memremap(phys, PAGE_SIZE, MEMREMAP_WC);
+
+		drm_info(dev,
+			 "rocket dbg prep_bo: iova=0x%llx size=0x%zx "
+			 "cached=%08x %08x %08x %08x  "
+			 "wc=%08x %08x %08x %08x\n",
+			 (unsigned long long)rkt_obj->mm.start,
+			 rkt_obj->size,
+			 cached[0], cached[1], cached[2], cached[3],
+			 wc ? wc[0] : 0xdeadbeef,
+			 wc ? wc[1] : 0xdeadbeef,
+			 wc ? wc[2] : 0xdeadbeef,
+			 wc ? wc[3] : 0xdeadbeef);
+
+		if (wc)
+			memunmap((void *)wc);
+	}
+
 	drm_gem_object_put(gem_obj);
 
 	return ret;
@@ -185,6 +223,9 @@ int rocket_ioctl_fini_bo(struct drm_device *dev, void *data, struct drm_file *fi
 	rkt_obj = to_rocket_bo(gem_obj);
 	shmem_obj = &rkt_obj->base;
 
+	drm_dbg(dev, "rocket dbg fini_bo: iova=0x%llx size=0x%zx\n",
+		(unsigned long long)rkt_obj->mm.start, rkt_obj->size);
+
 	dma_sync_sgtable_for_device(dev->dev, shmem_obj->sgt, DMA_BIDIRECTIONAL);
 
 	drm_gem_object_put(gem_obj);
diff --git a/drivers/accel/rocket/rocket_job.c b/drivers/accel/rocket/rocket_job.c
index 2c0b9bdff..720cbff79 100644
--- a/drivers/accel/rocket/rocket_job.c
+++ b/drivers/accel/rocket/rocket_job.c
@@ -7,11 +7,15 @@
 #include <drm/drm_file.h>
 #include <drm/drm_gem.h>
