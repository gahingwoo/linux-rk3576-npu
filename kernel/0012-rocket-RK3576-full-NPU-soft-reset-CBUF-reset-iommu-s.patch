 			clock-names = "aclk", "hclk", "npu", "pclk",
 				      "aclk_cbuf", "hclk_cbuf";
-			resets = <&cru SRST_A_RKNN0>;
-			reset-names = "srst_a";
+			resets = <&cru SRST_A_RKNN0>, <&cru SRST_A_RKNN_CBUF>,
+				 <&cru SRST_H_RKNN_CBUF>;
+			reset-names = "srst_a", "srst_cbuf_a", "srst_cbuf_h";
 			power-domains = <&power RK3576_PD_NPU0>;
