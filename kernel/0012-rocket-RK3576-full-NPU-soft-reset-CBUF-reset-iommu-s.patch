 	if (!vaddr) {
 		dev_err(core->dev, "regcmd dump: ioremap_cache failed\n");
@@ -67,9 +102,6 @@ static void dump_regcmd_dpu(struct rocket_core *core, struct rocket_job *job)
 		value  = (u32)((entry >> 16) & 0xffffffff);
 		reg    = (u16)(entry & 0xffff);
 
-		/* Diagnostic: print ALL regcmd entries (incl. CNA tgt=0x0201,
-		 * CORE tgt=0x0801) so CNA_CBUF_CON1 DATA_ENTRIES and every
-		 * op_en / enable write is visible. */
 		dev_info(core->dev,
 			 "  [%3u] tgt=%04x reg=%04x val=%08x\n",
 			 i, target, reg, value);
@@ -174,12 +206,145 @@ rocket_copy_tasks(struct drm_device *dev,
 	return ret;
 }
 
+/*
+ * One-shot conv0 channel-cap probe (diagnostic only).
+ *
+ * Established: conv0 reads the full feature (top dt_rd=9408) + full weights
+ * (wt_rd=96=1536B) from DRAM, geometry latches, all units engage -- yet only
+ * ~2 of 32 output channels reach DRAM (core dt_wr=25088), and the compute runs
+ * its course (~200us) then STOPS (not cut short by PC_DONE). The channel count
+ * GROWS across consecutive un-cleared kicks (0->2->6) and resets on pp CLEAR,
+ * which points at CBUF state, not a static reg value.
+ *
+ * Two phases, one flash:
+ *   Phase ACC: 16 consecutive kicks with NO pp CLEAR between, per-kick dt_wr.
