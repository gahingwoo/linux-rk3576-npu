diff --git a/drivers/accel/rocket/rocket_core.c b/drivers/accel/rocket/rocket_core.c
index eb6291826..00d12e5d9 100644
--- a/drivers/accel/rocket/rocket_core.c
+++ b/drivers/accel/rocket/rocket_core.c
@@ -22,6 +22,8 @@ int rocket_core_init(struct rocket_core *core)
 	int err = 0;
 
 	core->resets[0].id = "srst_a";
+	core->resets[1].id = "srst_cbuf_a";
+	core->resets[2].id = "srst_cbuf_h";
 	err = devm_reset_control_bulk_get_exclusive(&pdev->dev, ARRAY_SIZE(core->resets),
 						    core->resets);
 	if (err)
@@ -73,18 +75,31 @@ int rocket_core_init(struct rocket_core *core)
 		core->dpu_rdma_iomem = NULL;
 	}
 
+	/*
+	 * RK3576: the "pc" resource covers 0x1000 bytes (0x27700000–0x27700FFF).
+	 * pc_res->start + 0x2000 = 0x27702000 page holds the IOMMU regs (0x00–0x1FF)
+	 * AND the vendor perf/bandwidth counters (top @ +0x200, core @ +0x400).
+	 * A devm_platform_ioremap_resource for "stats" would request_mem_region and
+	 * collide with the IOMMU driver, so use a plain ioremap (no region request)
+	 * and only ever touch offsets >= 0x200 (the dt_wr/dt_rd/wt_rd counters),
+	 * never the IOMMU registers below 0x200.
+	 */
 	{
-		struct resource *pc_res = platform_get_resource_byname(pdev, IORESOURCE_MEM, "pc");
-
-		if (pc_res) {
-			core->stats_iomem = devm_ioremap(dev, pc_res->start + 0x2000, 0x1000);
-			if (IS_ERR_OR_NULL(core->stats_iomem))
-				core->stats_iomem = NULL;
-		} else {
-			core->stats_iomem = NULL;
-		}
+		struct resource *pc_res =
+			platform_get_resource_byname(pdev, IORESOURCE_MEM, "pc");
+
+		core->stats_iomem = NULL;
+		if (pc_res)
+			core->stats_iomem = ioremap(pc_res->start + 0x2000, 0x1000);
+		if (!core->stats_iomem)
+			dev_warn(dev, "no perf-counter mapping; dt_wr stats disabled\n");
 	}
 
+	/* Page for the RK3576 PC_DMA task descriptor (rknpu_task). */
+	core->task_desc = (void *)__get_free_page(GFP_KERNEL | __GFP_ZERO);
+	if (!core->task_desc)
+		dev_warn(dev, "no task-descriptor page; PC_DMA dispatch disabled\n");
+
 	dma_set_max_seg_size(dev, UINT_MAX);
 
 	err = dma_set_mask_and_coherent(dev, DMA_BIT_MASK(40));
@@ -118,6 +133,8 @@ int rocket_core_init(struct rocket_core *core)
 		return err;
 	}
 
+	rocket_core_pp_state_init(core);
+
 	version = rocket_pc_readl(core, VERSION);
 	version += rocket_pc_readl(core, VERSION_NUM) & 0xffff;
 
@@ -138,6 +155,13 @@ void rocket_core_fini(struct rocket_core *core)
 	rocket_job_fini(core);
 }
 
+/*
+ * Full NPU soft-reset, mirroring the vendor rknpu_soft_reset assert/deassert of
+ * all NPU resets (core AXI + both CBUF resets, see the resets[] comment). This
+ * resets the CBUF so the CNA->CBUF->CMAC path initialises; the caller is
+ * responsible for re-establishing the IOMMU (the reset also disturbs the MMU
+ * banks) and running rocket_core_pp_state_init() afterwards, in that order.
+ */
 void rocket_core_reset(struct rocket_core *core)
 {
 	reset_control_bulk_assert(ARRAY_SIZE(core->resets), core->resets);
@@ -145,4 +169,39 @@ void rocket_core_reset(struct rocket_core *core)
 	udelay(10);
 
 	reset_control_bulk_deassert(ARRAY_SIZE(core->resets), core->resets);
+
+	udelay(10);
+}
+
+/*
+ * RK3576 PP state machine init (mirrors rk3576_state_init in vendor rknpu).
+ * Must run on every power-up, not just at probe, because the PP state machine
+ * is reset by the power domain and its group registers are cleared.  Without
+ * this, the first task after each autosuspend cycle fires both PP groups
+ * simultaneously (CNA_STAT=0x5) using uninitialized Group-1 params (FDA=0),
+ * producing zero output that propagates through the entire inference graph.
+ */
+void rocket_core_pp_state_init(struct rocket_core *core)
+{
+	/* This resets the producer ping-pong pointer to group 0. */
+	core->pp_task_idx = 0;
+
+	rocket_pc_writel(core, BASE_ADDRESS, 0x1);
+	rocket_cna_writel(core, S_POINTER, 0x0);          /* POINTER=0, PP disabled */
+	rocket_cna_writel(core, DATA_SIZE1, 0x80000000);  /* activate Group 0 */
+	rocket_cna_writel(core, S_POINTER, 0x1);          /* POINTER=1, PP disabled */
+	rocket_cna_writel(core, DATA_SIZE1, 0x80000000);  /* activate Group 1 */
+	/*
+	 * Final write = 0x1e, matching vendor rk3576_state_init EXACTLY
+	 * (writel(0x1e, base+0x1004)): POINTER=0 | PP_MODE | EXECUTER_PP_EN |
+	 * POINTER_PP_EN | POINTER_PP_CLEAR. We previously used 0x1f (POINTER=1)
+	 * to dodge a task-1 STAT=0x5 double-fire, but the compute executers never
+	 * engage at all (bit16 never sets on CNA/CORE/DPU), so match the
+	 * authoritative vendor sequence and re-measure.
+	 */
+	rocket_cna_writel(core, S_POINTER,
+			  CNA_S_POINTER_POINTER_PP_MODE(1) |
+			  CNA_S_POINTER_EXECUTER_PP_EN(1)  |
+			  CNA_S_POINTER_POINTER_PP_EN(1)   |
+			  CNA_S_POINTER_POINTER_PP_CLEAR(1));
 }
diff --git a/drivers/accel/rocket/rocket_core.h b/drivers/accel/rocket/rocket_core.h
index 48eca77ab..2ee489f9b 100644
--- a/drivers/accel/rocket/rocket_core.h
+++ b/drivers/accel/rocket/rocket_core.h
@@ -13,6 +13,8 @@
 
 #include "rocket_registers.h"
 
+struct rocket_iommu_domain;
+
 #define rocket_pc_readl(core, reg) \
 	readl((core)->pc_iomem + (REG_PC_##reg))
 #define rocket_pc_writel(core, reg, value) \
@@ -50,10 +52,29 @@ struct rocket_core {
 	void __iomem *dpu_iomem;
 	void __iomem *dpu_rdma_iomem;
 	void __iomem *stats_iomem; /* NPU base+0x2000: dt_wr/dt_rd counters */
+	void *task_desc;	/* page for the RK3576 PC_DMA task descriptor */
 	struct clk_bulk_data clks[6];
-	struct reset_control_bulk_data resets[1];
+	/*
+	 * RK3576: the vendor soft-reset asserts the core AXI reset AND both CBUF
+	 * resets together (SRST_A_RKNN0 + SRST_A_RKNN_CBUF + SRST_H_RKNN_CBUF),
+	 * then re-attaches the IOMMU and runs state_init. The CBUF (convolution
+	 * buffer) only initialises as part of this coordinated reset; a standalone
+	 * or per-job CBUF reset leaves CNA/CORE inconsistent with it. Carry all
+	 * three so rocket_core_reset() can perform the full NPU reset.
+	 */
+	struct reset_control_bulk_data resets[3];
 
 	struct iommu_group *iommu_group;
+	/*
+	 * Attach-once IOMMU: the domain currently attached to iommu_group. rocket
+	 * used to attach in rocket_job_run and detach in the completion handler, i.e.
+	 * once per job; every attach runs rk_iommu_enable's raw MMU reset, which fails
+	 * if a per-job CBUF reset has disturbed the CBUF MMU bank. Instead, attach
+	 * lazily and keep it: a job only (re)attaches when the domain differs from
+	 * this one (context switch) or after a power cycle (runtime_suspend clears
+	 * it so resume re-attaches on a freshly powered, clean MMU). Holds a kref.
+	 */
+	struct rocket_iommu_domain *attached_domain;
 
 	struct mutex job_lock;
 	struct rocket_job *in_flight_job;
@@ -75,6 +96,24 @@ struct rocket_core {
 	struct work_struct poll_work;
 	atomic_t poll_active;
 
+	/*
+	 * Diagnostic: per-job record of whether each unit's EXECUTER bit
+	 * (S_POINTER bit16, HW-set while the executer is actively running) was
+	 * EVER observed set during execution.  Reading S_POINTER only at "done"
+	 * (post-completion) misses fast units, so hw_submit densely samples this
+	 * during the run.  Bitmask: 1=CNA 2=CORE 4=DPU 8=DPU_RDMA.
+	 */
+	u32 exec_ever;
+	u32 exec_samples;
+
+	/*
+	 * Ping-pong parity. The CNA producer alternates register group 0/1 per
+	 * dispatched task; the executer must read the same group. Counts tasks
+	 * since the last pp_state_init (which resets the producer to group 0) so
+	 * hw_submit can arm the executer's S_POINTER POINTER bit to match.
+	 */
+	u32 pp_task_idx;
+
 	struct drm_gpu_scheduler sched;
 	u64 fence_context;
 	u64 emit_seqno;
@@ -83,5 +122,6 @@ struct rocket_core {
 int rocket_core_init(struct rocket_core *core);
 void rocket_core_fini(struct rocket_core *core);
 void rocket_core_reset(struct rocket_core *core);
+void rocket_core_pp_state_init(struct rocket_core *core);
 
 #endif
diff --git a/drivers/accel/rocket/rocket_drv.c b/drivers/accel/rocket/rocket_drv.c
index 8f6a02d50..1aa2a5384 100644
--- a/drivers/accel/rocket/rocket_drv.c
+++ b/drivers/accel/rocket/rocket_drv.c
@@ -68,6 +68,23 @@ rocket_iommu_domain_put(struct rocket_iommu_domain *domain)
 	kref_put(&domain->kref, rocket_iommu_domain_destroy);
 }
 
+/*
+ * Attach-once teardown: detach whatever domain is currently bound to the core's
+ * IOMMU group and drop the core's kref. Called on context switch (rocket_job_run
+ * about to attach a different domain), on reset, and on runtime suspend (so the
+ * next resume re-attaches on a freshly powered MMU). No-op if nothing is attached.
+ */
+void
+rocket_core_detach_iommu(struct rocket_core *core)
+{
+	if (!core->attached_domain)
+		return;
+
+	iommu_detach_group(core->attached_domain->domain, core->iommu_group);
+	rocket_iommu_domain_put(core->attached_domain);
+	core->attached_domain = NULL;
+}
+
 static int
 rocket_open(struct drm_device *dev, struct drm_file *file)
 {
@@ -247,6 +264,21 @@ static int rocket_device_runtime_resume(struct device *dev)
 		return err;
 	}
 
+	/*
+	 * Full NPU soft-reset on every power-up (mirrors the vendor, which resets
+	 * the NPU incl. the CBUF at init). Done here, with clocks on and BEFORE any
+	 * IOMMU domain is attached (runtime_suspend detached it), so the reset's
+	 * disturbance of the MMU banks lands on an unattached MMU and the first job
+	 * after resume re-attaches (rk_iommu_enable) on a freshly reset, clean MMU
+	 * -- instead of a mid-operation CBUF reset corrupting an active attachment,
+	 * which is what broke earlier per-job CBUF-reset attempts. Without the CBUF
+	 * reset the CNA streams the full feature+weights from DRAM but the CMAC
+	 * reads zero out of an uninitialised CBUF (conv output = zero-point).
+	 */
+	rocket_core_reset(&rdev->cores[core]);
+
+	rocket_core_pp_state_init(&rdev->cores[core]);
+
 	return 0;
 }
 
@@ -261,6 +293,13 @@ static int rocket_device_runtime_suspend(struct device *dev)
 	if (!rocket_job_is_idle(&rdev->cores[core]))
 		return -EBUSY;
 
+	/*
+	 * Attach-once: the MMU loses its programming across this power-down, so drop
+	 * the attachment here (while still clocked) and let the first job after the
+	 * next resume re-attach on a clean, freshly powered MMU.
+	 */
+	rocket_core_detach_iommu(&rdev->cores[core]);
+
 	clk_bulk_disable_unprepare(ARRAY_SIZE(rdev->cores[core].clks), rdev->cores[core].clks);
 
 	return 0;
