From fbd3c71d84d4b78123de16bf2108734fb5a6b5af Mon Sep 17 00:00:00 2001
From: Jiaxing Hu <huhuvmb88@outlook.com>
Date: Mon, 8 Jun 2026 03:52:23 +1200
Subject: [PATCH 1/2] arm64: dts: rockchip: rk3576: add RKNN NPU subsystem

Add device tree nodes for the two RKNN neural processing unit cores
(rknn_core_0, rknn_core_1) and their IOMMU units (rknn_mmu_0,
rknn_mmu_1) on the RK3576 SoC.

Register addresses confirmed from the Rockchip vendor kernel
(linux-6.1-stan-rkr5.1, arch/arm64/boot/dts/rockchip/rk3576.dtsi):
  NPU core 0: pc@0x27700000, cna@0x27701000, core@0x27703000
  NPU core 1: pc@0x27710000, cna@0x27711000, core@0x27713000
  IOMMU 0:    0x27702000 + 0x27702100 (two 256-byte register banks)
  IOMMU 1:    0x2770a000 + 0x2770a100

Interrupt numbers (GIC_SPI 247 for core 0, GIC_SPI 248 for core 1)
confirmed from the vendor DTS.  Each core shares its interrupt line
with its IOMMU.

The IOMMU nodes use "rockchip,rk3568-iommu" as fallback compatible
because the RK3576 MMU is register-compatible with the RK3568 v2
design already supported by the rockchip-iommu driver.

Power domains are RK3576_PD_NPU0 and RK3576_PD_NPU1.  Resets use the
CRU SRST_A_RKNNx and SRST_A_RKNNx_BIU lines following the binding's
"srst_a"/"srst_h" reset-names convention.

All nodes are status = "disabled" by default; board files enable
individual cores.

Signed-off-by: Jiaxing Hu <huhuvmb88@outlook.com>
---
 arch/arm64/boot/dts/rockchip/rk3576.dtsi | 58 ++++++++++++++++++++++++
 1 file changed, 58 insertions(+)

diff --git a/arch/arm64/boot/dts/rockchip/rk3576.dtsi b/arch/arm64/boot/dts/rockchip/rk3576.dtsi
index e12a2a0cf..dd32b43d3 100644
--- a/arch/arm64/boot/dts/rockchip/rk3576.dtsi
+++ b/arch/arm64/boot/dts/rockchip/rk3576.dtsi
@@ -1804,6 +1804,64 @@ qos_npu_m1ro: qos@27f22100 {
 			reg = <0x0 0x27f22100 0x0 0x20>;
 		};

+		rknn_core_0: npu@27700000 {
+			compatible = "rockchip,rk3576-rknn-core";
+			reg = <0x0 0x27700000 0x0 0x1000>,
+			      <0x0 0x27701000 0x0 0x1000>,
+			      <0x0 0x27703000 0x0 0x1000>;
+			reg-names = "pc", "cna", "core";
+			interrupts = <GIC_SPI 247 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&cru ACLK_RKNN0>, <&cru HCLK_RKNN_ROOT>,
+				 <&cru CLK_RKNN_DSU0>, <&cru PCLK_NPUTOP_ROOT>;
+			clock-names = "aclk", "hclk", "npu", "pclk";
+			resets = <&cru SRST_A_RKNN0>, <&cru SRST_A_RKNN0_BIU>;
+			reset-names = "srst_a", "srst_h";
+			power-domains = <&power RK3576_PD_NPU0>;
+			iommus = <&rknn_mmu_0>;
+			status = "disabled";
+		};
+
+		rknn_mmu_0: iommu@27702000 {
+			compatible = "rockchip,rk3576-iommu", "rockchip,rk3568-iommu";
+			reg = <0x0 0x27702000 0x0 0x100>,
+			      <0x0 0x27702100 0x0 0x100>;
+			interrupts = <GIC_SPI 247 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&cru ACLK_RKNN0>, <&cru HCLK_RKNN_ROOT>;
+			clock-names = "aclk", "iface";
+			#iommu-cells = <0>;
+			power-domains = <&power RK3576_PD_NPU0>;
+			status = "disabled";
+		};
+
+		rknn_core_1: npu@27710000 {
+			compatible = "rockchip,rk3576-rknn-core";
+			reg = <0x0 0x27710000 0x0 0x1000>,
+			      <0x0 0x27711000 0x0 0x1000>,
+			      <0x0 0x27713000 0x0 0x1000>;
+			reg-names = "pc", "cna", "core";
+			interrupts = <GIC_SPI 248 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&cru ACLK_RKNN1>, <&cru HCLK_RKNN_ROOT>,
+				 <&cru CLK_RKNN_DSU0>, <&cru PCLK_NPUTOP_ROOT>;
+			clock-names = "aclk", "hclk", "npu", "pclk";
+			resets = <&cru SRST_A_RKNN1>, <&cru SRST_A_RKNN1_BIU>;
+			reset-names = "srst_a", "srst_h";
+			power-domains = <&power RK3576_PD_NPU1>;
+			iommus = <&rknn_mmu_1>;
+			status = "disabled";
+		};
+
+		rknn_mmu_1: iommu@2770a000 {
+			compatible = "rockchip,rk3576-iommu", "rockchip,rk3568-iommu";
+			reg = <0x0 0x2770a000 0x0 0x100>,
+			      <0x0 0x2770a100 0x0 0x100>;
+			interrupts = <GIC_SPI 248 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&cru ACLK_RKNN1>, <&cru HCLK_RKNN_ROOT>;
+			clock-names = "aclk", "iface";
+			#iommu-cells = <0>;
+			power-domains = <&power RK3576_PD_NPU1>;
+			status = "disabled";
+		};
+
 		gmac0: ethernet@2a220000 {
 			compatible = "rockchip,rk3576-gmac", "snps,dwmac-4.20a";
 			reg = <0x0 0x2a220000 0x0 0x10000>;
--
