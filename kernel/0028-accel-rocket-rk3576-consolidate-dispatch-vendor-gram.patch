- * weakly argues against a producer/consumer group mismatch; this is a cheap
- * long shot, and the compact per-task "rocket pp" line is what actually decides.
- */
-static int rocket_pp_alt;
-module_param_named(pp_alt, rocket_pp_alt, int, 0644);
-MODULE_PARM_DESC(pp_alt, "seq-kick: alternate S_POINTER POINTER = (per-job task index & 1) per kick (patches CNA 0x1004 / CORE 0x3004 regcmd entries too); task 0 stays group 0. Default 0.");
