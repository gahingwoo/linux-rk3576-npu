-/*
  * Board-debug knob: override the CNA/CORE S_POINTER arming value (and patch the
  * regcmd's own 0x1004/0x3004 S_POINTER entries to match) so the ping-pong
  * group selection can be swept on the board. conv0's geometry lands in the
@@ -196,112 +166,6 @@
 MODULE_PARM_DESC(perjob_ppinit, "Re-run pp_state_init at the head of every job (default 1)");
 
 /*
- * Fork A warm-chain: run pp_state_init only on the FIRST task of a job (the cold
- * start that needs the arming to engage), and SKIP it on the sequential re-kicks
- * (tasks after the first within the same job). pp_state_init's POINTER_PP_CLEAR
- * cools the on-chip CBUF between kicks -- the CNA reads a cleared group instead of
- * the buffer the previous task just wrote, so the layer chain reads empty. Each
- * task's regcmd arms its own S_POINTER (mesa writes 0x1004 per task), so the first
- * kick's pp_state_init suffices; skipping it on re-kicks keeps the CBUF warm across
- * layers the way the vendor's continuous submit does, while still using the proven
- * per-task single kick for engage. rocket.wg_warm_chain (default 0 = off).
- */
-static int rocket_wg_warm_chain;
-module_param_named(wg_warm_chain, rocket_wg_warm_chain, int, 0644);
-MODULE_PARM_DESC(wg_warm_chain, "Skip pp_state_init on within-job re-kicks to keep CBUF warm across layers (default 0)");
-
-/*
- * Fork A continuous submit: dispatch the whole job as ONE PC submit with
- * task_number = task_count (the vendor rknpu_job_subcore_commit_pc model), letting
- * the PC iterate all tasks from a single OP_EN pulse, instead of the N sequential
- * single-task kicks (task_number=1, one advance per DPU-done). This is the mode
- * that pre-stages the next layer's weights into CBUF while the current computes
- * (the double-buffer the sequential kicks lack -> pointwise weight_rd=0). The known
- * wall: the PC engages task 0's units (exec_ever=0xf) but task 0 never completes
- * its DPU write (distinct=1, PC_TASK_STATUS stuck at 0) -> PC stalls; the SAME task
- * 0 completes as a task_number=1 kick. Pair with multitask_poll=1 (waits
- * TASK_STATUS==task_count, 500ms safe cap) to A/B task-0's live status against the
- * sequential path on one build. rocket.wg_continuous (default 0 = sequential kick).
- */
-static int rocket_wg_continuous;
-module_param_named(wg_continuous, rocket_wg_continuous, int, 0644);
-MODULE_PARM_DESC(wg_continuous, "Dispatch the whole job as one task_number=N PC submit (Fork A), not N sequential single-task kicks (default 0)");
-
-/*
- * bare_tasknum: the vendor's BARE task_number=N HW-iteration mode. wg_continuous
- * already submits ONCE (task_number=N, no per-task re-kick); the only per-run
- * driver intervention left is the cnalive busy-poll (4000x register reads during
- * execution). Set bare_tasknum=1 (with wg_continuous=1) to SKIP that busy-poll so
- * the PC iterates natively with zero driver register access during the run --
- * just submit, one OP_EN, wait for the single final completion, then read back.
- * Tests whether native HW iteration self-arms the CSC (chained core wt_rd/output)
- * without any injected re-arm. Default 0.
- */
-static int rocket_bare_tasknum;
-module_param_named(bare_tasknum, rocket_bare_tasknum, int, 0644);
-MODULE_PARM_DESC(bare_tasknum, "Skip the per-run cnalive busy-poll so the PC iterates task_number=N natively with no driver intervention during the run (use with wg_continuous=1). Default 0.");
-
-/*
- * Fork B teardown bisect (2026-07-04). The mesa dw regcmd is byte-identical to the
- * vendor's, yet only the cold-start task 0 does MACs; every re-kick reads its input
- * with a correct regcmd but the CMAC never fires. The vendor's continuous PC submit
- * does NO teardown between tasks; our sequential kicks do. This bitmask disables the
- * per-kick teardown one step at a time to find which one kills the MACs on a re-kick:
- *   0x1  skip the done-handler diagnostic CNA S_POINTER 0->1->restore toggle (a write
- *        the vendor never does, between every kick — could disturb the CBUF group).
- *   0x2  skip the driver S_POINTER re-arm (0xe) on re-kicks (task 1+); the task's own
- *        regcmd re-arms 0x1004/0x3004, so the extra driver write may be redundant AND
- *        re-init the executer/ping-pong the vendor leaves alone.
- *   0x4  minimal INTERRUPT_CLEAR at completion (only PC_DONE, not the full 0x1ffff
- *        that also clears every CNA/CORE/DPU sub-stage event).
- *   0x8  skip the per-kick perf-counter clear (writes to the stats page between kicks).
- * bisect=0xf (skip all) vs 0 (baseline) is the decisive first cut: if 0xf makes task 1
- * compute (distinct>10), bisect down; if 0xf still fails, the teardown is NOT the cause
- * (it's the fresh-power/cold-start HW state task 0 alone has). rocket.bisect (default 0).
- */
-static int rocket_bisect;
-module_param_named(bisect, rocket_bisect, int, 0644);
-MODULE_PARM_DESC(bisect, "Bitmask: disable per-kick teardown steps to find the MAC-killer (0x1 sptr-toggle, 0x2 sptr-rearm, 0x4 int-clear, 0x8 perf-clear; default 0)");
-
-/*
- * Fork B re-kick reset (2026-07-04). The runtime_resume callback runs a full NPU
- * soft-reset (rocket_core_reset) that initialises the CBUF; without it "the CMAC
- * reads zero out of an uninitialised CBUF" (rocket_drv.c comment). conv0, the first
- * task after resume, runs on that fresh CBUF and does MACs; every re-kick rides the
- * same powered session with a CBUF the previous task left, and the CMAC produces
- * zero. This knob re-runs the soft-reset before each re-kick (task 1+) to give every
- * layer the fresh-CBUF the cold start gets:
- *   1  bare rocket_core_reset (may corrupt the attached NPU-MMU banks -> stale DMA).
- *   2  detach IOMMU -> reset -> re-attach (the resume sequence: reset lands on an
- *      unattached MMU, then re-attach on a clean one) -> then the normal re-config.
- * Pair with soft_reset=0 (disable the resume reset) as the mechanism control: if that
- * makes conv0 go zero, the resume soft-reset IS the MAC-enabler. rocket.rekick_reset
- * (default 0). WARNING: mid-graph reset is the domain the prior cbuf_reset=2 /
- * power-cycle attempts corrupted (-14 / hang); treat 1 and 2 as experiments.
- */
-static int rocket_rekick_reset;
-module_param_named(rekick_reset, rocket_rekick_reset, int, 0644);
-MODULE_PARM_DESC(rekick_reset, "Re-run the NPU soft-reset before each re-kick (1 bare, 2 detach+reset+reattach; default 0)");
-
-/*
- * Chained-submit task_number field override (2026-07-04). The next-pointer board
- * result proved the RK3576 PC follows the trailer (conv0->dw1), but with the
- * wg_continuous PC_TASK_CON task_number=task_count the MAC is EMPTY even for task 0
- * (output distinct=1) and the chain stalls after one hop. The SAME conv0 does a real
- * MAC as a task_number=1 kick (distinct=239): the empty MAC is gated by the task_
- * number FIELD value. Upstream RK3588 rocket sets PC_TASK_CON_TASK_NUMBER(1) AND
- * relies on the trailer to advance — our task_number=task_count was the deviation.
- * This overrides ONLY the task_number field in the wg_continuous submit; the trailer
- * (mesa ROCKET_NEXTPTR) still advances the PC, and the completion still waits for the
- * whole chain (PC_TASK_STATUS==task_count, 500ms cap) because that path keys off
- * job->task_count, not this field. Set 1 to run each chained task in committing mode.
- * rocket.chain_task_number (0 = use task_count, current; >0 = force this value).
- */
-static int rocket_chain_task_number;
-module_param_named(chain_task_number, rocket_chain_task_number, int, 0644);
-MODULE_PARM_DESC(chain_task_number, "In the wg_continuous chained submit, force PC_TASK_CON task_number to this value (0=task_count). Use 1 to run each next-pointer-chained task in committing mode.");
