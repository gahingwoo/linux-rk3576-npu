-/*
- * open_high: upstream RK3588's per-task arm model. Our seq-kick pulses PC OP_EN
- * 1->0 AT SUBMIT (OP_EN=0 during execution); upstream sets OP_EN=1 and leaves it
- * HIGH through execution, clearing to 0 only at completion (handle_irq already
- * does OP_EN=0 + INT_CLEAR=0x1ffff). Hypothesis: the completion-time OP_EN 1->0 is
- * the HW's per-task re-arm; our submit-pulse skips it for re-kicks. When set, drop
- * the submit OP_EN=0 pulse (leave OP_EN high) and treat DPU-done (raw & 0x300) as
- * completion (the inline exec loop + the poll both check it) since PC_DONE (bits
- * 28/29) may not assert while OP_EN is high. The poll cap below is unconditional so
- * this can never hang -> sched-timeout -> rocket_core_reset -> shared rk_iommu death.
- */
-static int rocket_open_high;
-module_param_named(open_high, rocket_open_high, int, 0644);
-MODULE_PARM_DESC(open_high, "Upstream-style per-task arm: leave PC OP_EN HIGH through execution (drop the submit OP_EN=0 pulse), complete on DPU-done. Default 0.");
