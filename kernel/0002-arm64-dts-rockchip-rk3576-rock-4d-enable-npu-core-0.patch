From a7804041781b40c9e440653a5a7e6d4c2cd960a5 Mon Sep 17 00:00:00 2001
From: Jiaxing Hu <huhuvmb88@outlook.com>
Date: Mon, 8 Jun 2026 03:52:23 +1200
Subject: [PATCH 2/2] arm64: dts: rockchip: rk3576-rock-4d: enable NPU core 0

Enable the first RKNN NPU core and its IOMMU on the Radxa ROCK 4D
board.  The npu-supply is the vdd_npu_s0 DCDC rail (RK806, 550-950 mV)
shared by both NPU cores.

Only core 0 is enabled; core 1 remains disabled pending further
board-level validation.

Signed-off-by: Jiaxing Hu <huhuvmb88@outlook.com>
---
 arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts b/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
index 272af1012..aff38e8c4 100644
--- a/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
@@ -869,3 +869,12 @@ vp0_out_hdmi: endpoint@ROCKCHIP_VOP2_EP_HDMI0 {
 		remote-endpoint = <&hdmi_in_vp0>;
 	};
 };
+
+&rknn_core_0 {
+	npu-supply = <&vdd_npu_s0>;
+	status = "okay";
+};
+
+&rknn_mmu_0 {
+	status = "okay";
+};
--
2.43.0
