+         const float *wscales = poperation->conv.weight_tensor->scales;
+         float max_sc = wscales ? wscales[0] : 1.0f;
+         if (wscales)
+            for (unsigned oc = 1; oc < output_channels; oc++)
+               if (wscales[oc] > max_sc)
+                  max_sc = wscales[oc];
+
+         for (unsigned oc = 0; oc < output_channels; oc++) {
+            int32_t sw = calculate_weight_sum(poperation, oc, weights);
+            unsigned g = oc / 8, i = oc % 8;
+            int32_t *A = (int32_t *)(b8 + g * 64 + i * 4);
+            int16_t *B = (int16_t *)(b8 + g * 64 + 32 + i * 2);
+            int16_t *C = (int16_t *)(b8 + g * 64 + 48 + i * 2);
+            float rel = wscales ? (wscales[oc] / max_sc) : 1.0f;
+            *A = a_scale * (sw + biases_in[oc]);
+            *B = (int16_t)(0x80 - (int)wt_zp);
+            *C = (int16_t)(16384.0f * rel + 0.5f);
+         }
       }
 
