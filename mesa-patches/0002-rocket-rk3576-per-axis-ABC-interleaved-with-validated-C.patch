-      unsigned bufsize = groups * 64 + 0x100;   /* structure + zeroed X2 pad */
+      /*
+       * The DPU_RDMA reads a per-channel BS *float* surface from 0x5024 (=
+       * bias + groups*64) for ALL output channels. The vendor's buffer for this
+       * conv is 20800B; ours was groups*64+0x100 = 1280B, so the RDMA read ran
+       * ~19.5KB past the BO end -> IOMMU fault / RDMA stall -> the CMAC read zero
+       * weights (core wt_rd=0) = the wall. Size the BO to cover the read: the int
+       * A/B/C table (groups*64) plus a float region bounded by the full weight
+       * count (the float surface can hold no more floats than there are weights).
+       * The float content stays zeroed here -- filling it with the dequant-weight
+       * surface is a separate TODO; this only stops the out-of-bounds stall.
+       */
+      unsigned wt_elems = poperation->conv.weight_tensor->dims[0] *
+                          poperation->conv.weight_tensor->dims[1] *
+                          poperation->conv.weight_tensor->dims[2] *
+                          poperation->conv.weight_tensor->dims[3];
+      unsigned bufsize = groups * 64 + wt_elems * sizeof(float) + 0x100;
       uint8_t *b8;
 
       /*
@@ -368,17 +383,53 @@ rkt_fill_biases(struct rkt_ml_subgraph *subgraph,
       b8 = pipe_buffer_map(pcontext, rsc, PIPE_MAP_WRITE, &transfer_out);
