@@ -311,7 +311,9 @@ fill_regcmd_rk3576_normal(struct rkt_ml_subgraph *subgraph,
 
    unsigned surf = inw * ic / 64;                /* input CBUF surface stride */
    unsigned wbpk = dw ? (k * k * ic / 8) : (ic * k * k * 2); /* weight bytes/kernel */
-   unsigned k_word = (k >= 3) ? 0x0202 : 0;
+   /* k_word tracks the kernel extent: per-byte = (k-1) (k=3 -> 0x0202, k=5 ->
+    * 0x0404). Was hard-coded to the k=3 value, which mis-fetched weights for k=5. */
+   unsigned k_word = (k >= 3) ? (((k - 1) << 8) | (k - 1)) : 0;
    uint32_t reuse = (wnum > 0) ? task->cbuf_reuse_row * surf : 0;  /* DATA_REUSE base */
 
    /*
@@ -368,7 +370,9 @@ fill_regcmd_rk3576_normal(struct rkt_ml_subgraph *subgraph,
    R_CNA(0x100c, dw ? 0x1 : 0x0);
    R_CNA(0x1010, 0x00000fff);
    R_CNA(0x1014, (s << 3) | s);
-   R_CNA(0x1018, 0x40000505 | (wnum > 0 ? 0x80000000 : 0));
+   /* stride-2 wants 0x...0404 (both the conv0 capture and this k=5 s=2 conv);
+    * 0x...0505 was the stride-1 value the generic path was calibrated on. */
+   R_CNA(0x1018, (s == 2 ? 0x40000404 : 0x40000505) | (wnum > 0 ? 0x80000000 : 0));
    R_CNA(0x101c, dw ? (oc * k * k * 2) : (ic * oc * k * k));
    R_CNA(0x1020, (dw ? oc : ic) * k * k);
    R_CNA(0x1024, (k_word << 16) | (dw ? 1 : (oc - 1)));
@@ -378,7 +382,9 @@ fill_regcmd_rk3576_normal(struct rkt_ml_subgraph *subgraph,
    R_CNA(0x1034, ow * win_orows - 1);
    R_CNA(0x1038, 0x07 | (wnum > 0 ? 0x80000000 : 0));
    R_CNA(0x103c, (surf << 16) | reuse);
-   R_CNA(0x1040, 0x14000000 | (wnum > 0 ? task->cbuf_input_row_start * surf : 0));
+   /* CBUF_CON0: stride-2 captures (conv0 and this conv) use 0x10000000, not the
+    * generic-path 0x14000000 (the 0x04000000 bit is a stride-1 artifact). */
+   R_CNA(0x1040, (s == 2 ? 0x10000000 : 0x14000000) | (wnum > 0 ? task->cbuf_input_row_start * surf : 0));
    R_CNA(0x1044, (inw << 16) | surf);
    R_CNA(0x1048, 0x0000000b);
    R_CNA(0x104c, 0x00010001);   /* CVT bypass (requant is in DPU OUT_CVT) */
@@ -394,7 +400,9 @@ fill_regcmd_rk3576_normal(struct rkt_ml_subgraph *subgraph,
    R_CNA(0x1074, 0x00000000);
    R_CNA(0x1078, ((inw - 1) << 16) | (win_irows - 1));
    R_CNA(0x107c, ic - 1);
-   R_CNA(0x1080, s == 2 ? 0x101
+   /* stride-2: depthwise (conv0) uses 0x00000101; a normal conv needs the
+    * 0x0202 SURF_STRIDE high field (vendor capture of this k=5 s=2 conv). */
+   R_CNA(0x1080, s == 2 ? (dw ? 0x101 : 0x02020101)
                         : (dw ? (capped ? (wnum > 0 ? 0x01010100 : 0x01000101)
                                         : 0x01010101)
                               : 0));
