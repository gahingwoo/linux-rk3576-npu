+      emit_raw(regs, 0x801, 0x3008, uo);   /* CORE OP_EN */
+      emit_raw(regs, 0x1001, 0x4008, uo);  /* DPU  OP_EN */
+      emit_raw(regs, 0x2001, 0x5008, uo);  /* RDMA OP_EN */
+   }
 
