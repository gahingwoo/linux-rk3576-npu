    R_RDMA(0x507c, 0x00000000);
 
-   emit_raw(regs, 0x81, REG_PC_OPERATION_ENABLE, 0x1d);
+   /*
+    * Engage the units. The broadcast op_en (0x81/0x08/0x1d) writes the PC's OWN
+    * PC_OPERATION_ENABLE and RESTARTS the PC mid-stream, engaging the units before
+    * the geometry is committed -> they run on an empty window (board: ds0_first=-1,
+    * core wt_rd=0, MAC=0). Fully stripping it lets the geometry latch (ds0_first=0,
+    * ds0=0x190) but the kernel's single 0x1 pulse never engages the units
+    * (exec_ever=0). So engage each unit at its OWN OP_EN (CNA 0x1008 / CORE 0x3008 /
