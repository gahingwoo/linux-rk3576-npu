#!/bin/sh
# ---------------------------------------------------------------------------
# Boot-time RK3576 NPU PVTPLL-crawl diagnostic — one inference, full telemetry.
#
# PVTPLL (scmi 238 @ 800 MHz, 800 mV) makes the NPU crawl. Run a SINGLE
# inference in the background, let it run ~90 s, kill it, then print to serial:
#   - the clk/voltage that got set (captured BEFORE clearing dmesg)
#   - how many jobs timed out / reset (the crawl signature)
#   - the first couple of layers' done/perf/rawor/cnalive
# So we learn WHY it crawls (job timeout vs slow compute vs reset loop).
# (No `timeout` applet in busybox, so use bg + sleep + kill.)
# ---------------------------------------------------------------------------

NPU_DIR=/opt/npu-test
MODEL="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
IMG="$NPU_DIR/grace_hopper.jpg"
INFER_LOG=/tmp/npu-infer.log
DMESG_LOG=/tmp/npu-dmesg.log
CLK_LOG=/tmp/npu-clk.txt
export TEFLON_LIB=/usr/lib/libteflon.so
C=/dev/console

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { echo "npudiag: no accel device" > "$C"; return 0; }

	dmesg -n 8 2>/dev/null
	# Capture the boot-time clock/voltage lines BEFORE clearing the ring.
	dmesg 2>/dev/null | grep -E "npu_uv_set|npu_clk_set|rocket dbg clk:" > "$CLK_LOG"
	dmesg -c >/dev/null 2>&1

	echo "" > "$C"
	echo "########## NPU PVTPLL-CRAWL DIAG (one inference, ~90s) ##########" > "$C"

	# Single inference in the background; let it run, then kill it.
	t0=$(cut -d. -f1 /proc/uptime)
	python3 "$NPU_DIR/infer.py" "$MODEL" "$IMG" > "$INFER_LOG" 2>&1 &
	PID=$!
	w=0
	while [ "$w" -lt 90 ] && kill -0 "$PID" 2>/dev/null; do sleep 5; w=$((w + 5)); done
	finished=1; kill -0 "$PID" 2>/dev/null && finished=0
	kill "$PID" 2>/dev/null; kill -9 "$PID" 2>/dev/null
	t1=$(cut -d. -f1 /proc/uptime)
	dmesg > "$DMESG_LOG" 2>/dev/null

	{
		echo "----- clock/voltage that got set -----"
		cat "$CLK_LOG" 2>/dev/null
		echo "----- crawl signature -----"
		printf "  job 'timed out':   %s\n" "$(grep -ic 'timed out\|timedout\|drm_sched' "$DMESG_LOG" 2>/dev/null)"
		printf "  'reset' lines:     %s\n" "$(grep -ic 'reset' "$DMESG_LOG" 2>/dev/null)"
		printf "  'dbg done' lines:  %s  (= jobs that completed in the window)\n" "$(grep -c 'rocket dbg done' "$DMESG_LOG" 2>/dev/null)"
		echo "----- first 2 layers' telemetry -----"
		for tag in "rocket dbg done" "rocket dbg perf" "rocket dbg rawor" "rocket dbg cnalive"; do
			grep "$tag" "$DMESG_LOG" 2>/dev/null | head -2
		done
		echo "----- inference outcome -----"
		printf "  infer finished=%s in window  wall=%ss\n" "$finished" "$((t1 - t0))"
		grep -E "Raw non-zero|Top-1 index|CPU Top-1|INFERENCE OK|FAIL|Traceback|Error" "$INFER_LOG" 2>/dev/null | head -5
		echo "----- raw: $INFER_LOG  $DMESG_LOG -----"
		echo "########## END PVTPLL-CRAWL DIAG ##########"
		echo ""
	} > "$C" 2>&1
}

case "$1" in
	start) start ;;
	stop) : ;;
	restart) start ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
