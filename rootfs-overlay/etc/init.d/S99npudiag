#!/bin/sh
exit 0  # NEUTRALIZED 2026-07-03: verdict test (S98) runs alone
# ---------------------------------------------------------------------------
# RK3576 NPU — REAL-MESA cnalive validation (single submit).
#
# Goal: capture the kernel cnalive (ds0_first) for the REAL Mesa Teflon conv2d,
# NOT the replay_mesa reconstruction. This is the FIRST and ONLY NPU job after
# boot, so the kernel audit (rocket.audit_arm, default 1, self-clears after the
# first job) fires on the genuine Mesa payload.
#
#   ds0_first == -1  -> geometry never reaches the CNA in the real Mesa path too
#                       => replay_mesa is FAITHFUL, bug = geometry delivery/submit
#   ds0_first ==  0  -> geometry DID reach the CNA in the real path but output is
#                       still degenerate => bug = DATA, replay_mesa is UNFAITHFUL
#
# Single test_conv.py run = one NPU submit (the CPU leg never touches the NPU),
# so no multi-submit BO-cleanup crash.
# ---------------------------------------------------------------------------

NPU_DIR=/opt/npu-test
M="$NPU_DIR/conv2d.tflite"
export TEFLON_LIB=/usr/lib/libteflon.so
C=/dev/console

log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "npu-test: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null
	dmesg -c >/dev/null 2>&1

	log ""
	log "########## REAL-MESA cnalive VALIDATION (single submit) ##########"
	log "----- real Mesa Teflon conv2d (NPU vs CPU) -----"
	python3 "$NPU_DIR/test_conv.py" "$M" > /tmp/cmp.log 2>&1 &
	PID=$!; w=0; while [ "$w" -lt 60 ] && kill -0 "$PID" 2>/dev/null; do sleep 3; w=$((w+3)); done
	kill -9 "$PID" 2>/dev/null
	cat /tmp/cmp.log > "$C"

	log "----- kernel cnalive for that REAL-MESA job (ds0_first is the verdict) -----"
	dmesg | grep -aE 'cnalive|rocket dbg perf|rocket dbg done|rocket dbg open|rocket dbg exec|rocket dbg CNA:' > "$C"

	log ""
	log "########## END real-mesa validation ##########"
	log ""
}

case "$1" in
	start) start ;;
	stop) : ;;
	restart) start ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
