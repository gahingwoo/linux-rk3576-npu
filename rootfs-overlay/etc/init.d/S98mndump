#!/bin/sh
# ---------------------------------------------------------------------------
# Single-task depthwise DPU-vs-MAC probe (2026-06-30). NO_DW_TILE makes dw1 a
# SINGLE task (no multi-task confound) and it STILL outputs exact 0x00 while
# single-task standard convs compute -> the wall is depthwise-MODE, not
# task_count. Now split WHY the single-task dw writes nothing:
#   ROCKET_DW_ATEST forces A (the requant ALU add) to 0x2000; output =
#   requant(MAC + A). dw1 out NONZERO -> the dw DPU/requant/write path is alive
#   and A flows -> the zero is the MAC/CBUF weight read (-> on-chip nbuf
#   residency the vendor uses, rocket lacks). dw1 out still 0x00 -> the dw
#   DPU/output path itself is dead.
# Both runs use ROCKET_NO_DW_TILE so dw1 is single-task (clean).
# ---------------------------------------------------------------------------

NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
log() { echo "$@" > "$C"; }

run() {  # $1 = label, $2 = mesa env
	dmesg -c >/dev/null 2>&1
	log ""
	log "########## $1 ##########"
	env TEFLON_LIB=/usr/lib/libteflon.so $2 python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1
	log "---- per-layer buffers (task0=conv0 task0/buf3=dw1 ...) ----"
	dmesg | grep -E "rocket dbg buf\[" | grep -vE "@0x|cover16K|fine256" > "$C" 2>&1
	log "########## END $1 ##########"
	sleep 7
}

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "dwprobe: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null
	echo 0 > /sys/module/rocket/parameters/audit_arm 2>/dev/null
	for f in $(find /sys/devices -path '*npu*/power/control' 2>/dev/null); do echo on > "$f" 2>/dev/null; done
	for f in $(find /sys/devices -path '*npu*/power/autosuspend_delay_ms' 2>/dev/null); do echo 120000 > "$f" 2>/dev/null; done
	echo 1 > /sys/module/rocket/parameters/multitask_poll 2>/dev/null
	echo 0 > /sys/module/rocket/parameters/wg_force_tasknum 2>/dev/null

	log "===== SINGLE-TASK DEPTHWISE: DPU-vs-MAC (NO_DW_TILE; ATEST forces A to the output) ====="
	# Run A FIRST (fresh buf-dump counter) = the ATEST.
	run "A  NO_DW_TILE + DW_ATEST  (force A=0x2000 -- dw1 out nonzero? => DPU alive, MAC is the fault)" \
	    "ROCKET_NO_DW_TILE=1 ROCKET_DW_ATEST=1"
	run "B  NO_DW_TILE only  (real A -- single-task dw baseline, expect zero)" \
	    "ROCKET_NO_DW_TILE=1"
	log "===== DONE: compare dw1 (buf[3] task=0) OUT: A (forced-A) vs B (real-A) ====="
	log ""
}

case "$1" in
	start) start ;;
	stop) : ;;
	restart) start ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
