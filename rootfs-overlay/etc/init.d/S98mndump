#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 zero_out_bos ground truth (2026-07-04). open_high refuted; one loose end
# left: per-completion core dt_wr grew (25088,45248,50176,90944...) which fits
# neither "only conv0 computes" nor a clean counter. distinct can read STALE data
# on a reused BO (conv0_twice trap), so this zeros every output BO before the run
# and scans the WHOLE BO after, classifying each task EMPTY / ZEROPOINT / REAL.
#   Regime: seq-kick (WHOLE_GRAPH, wg_continuous=0) + warm_chain=1, zero_out_bos=1.
#   WATCH "rocket groundtruth task=N ... class=":
#     - conv0 (task=0) REAL + every later task EMPTY/ZEROPOINT => chained layers
#       write nothing real; dt_wr growth is a dirty counter; software line CLOSED
#       (pivot below software: NVDLA CSC/CMAC RTL / RK3576 quirk).
#     - ANY later task REAL (distinct>2, spread) => CMAC fired, output mis-routed
#       => REVERSAL, chase the address not the arm.
#   Also "rocket dtwr task=N ... delta=" shows whether dt_wr tracks real outputs.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "zero_out_bos: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	# ---- regime: seq-kick + warm-chain ----
	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 0 > $P/bisect 2>/dev/null
	echo 0 > $P/rekick_reset 2>/dev/null
	echo 1 > $P/wg_warm_chain 2>/dev/null
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	echo 0 > $P/chain_task_number 2>/dev/null
	echo 0 > $P/geom_both 2>/dev/null
	echo 0 > $P/geom_all 2>/dev/null
	echo 0 > $P/conv0_twice 2>/dev/null
	echo 0 > $P/open_high 2>/dev/null
	echo 0 > $P/audit_all 2>/dev/null
	echo 0 > $P/audit_arm 2>/dev/null

	# ---- zero output BOs before the run + whole-BO classify after ----
	echo 1 > $P/zero_out_bos 2>/dev/null

	dmesg -c >/dev/null 2>&1
	log ""
	log "===== ZERO_OUT_BOS: seq-kick, zero every output BO pre-run, whole-BO classify ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	log "===== ZERO_OUT_BOS DONE: conv0 REAL + all later EMPTY/ZEROPOINT = wall; any later REAL = reversal ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
