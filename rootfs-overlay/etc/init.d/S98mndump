#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 geom_both A/B (2026-07-04). Stage-2 init audit landed on the ping-pong
# latch: the CMAC executer reads its CNA/CORE geometry from the active PP-group,
# but regcmd(PC) writes don't reliably latch there (both groups read the
# pp_state_init default DS1=0x80000000) -- only CPU writes latch. geom_both
# CPU-replicates each task's regcmd CNA/CORE config into BOTH groups before OP_EN.
# It was tried long ago (when it "ruled out geometry"), but ONLY back when dw1
# didn't even read its input -- config was moot. Now (all-tasks readback) dw1
# READS conv0's real output (in task=1 distinct=244) yet MACs to zero. So force
# dw1's config into the PP-group and see if it now computes.
#   Regime: seq-kick (WHOLE_GRAPH, wg_continuous=0) + warm_chain=1 = the mode
#   where dw1 reads dt_rd=20384. The all-tasks readback prints one "out task=N"
#   line per layer.
#   RUN A  geom_both=0 (baseline): expect out task=0 (conv0) distinct>200,
#            out task=1 (dw1) distinct=1 -- the known wall.
#   RUN B  geom_both=1 (THE TEST): watch out task=1 (dw1).
#            - task=1 distinct>1  => config wasn't latching; geom_both opened it.
#            - task=1 distinct=1  => not config; it's CNA->CBUF->CMAC data
#              staging -> pivot to NBUF/CBUF structural.
#            - task=0 distinct drops to 1 => geom_both BROKE conv0 (informative).
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "geom_both: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	# ---- common regime: seq-kick + warm-chain (dw1 reads its input here) ----
	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 0 > $P/bisect 2>/dev/null
	echo 0 > $P/rekick_reset 2>/dev/null
	echo 1 > $P/wg_warm_chain 2>/dev/null
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	echo 0 > $P/chain_task_number 2>/dev/null

	# ---- RUN A: geom_both=0 (baseline) ----
	echo 0 > $P/geom_both 2>/dev/null
	dmesg -c >/dev/null 2>&1
	log ""
	log "===== GEOM_BOTH RUN A: geom_both=0 (baseline seq-kick) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	# ---- RUN B: geom_both=1 (THE TEST) ----
	echo 1 > $P/geom_both 2>/dev/null
	log ""
	log "===== GEOM_BOTH RUN B: geom_both=1 (CPU-replicate config into both PP groups) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	log "===== GEOM_BOTH DONE: compare 'out task=1' distinct A(=0) vs B(=1); >1 in B = config-latch was the miss ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
