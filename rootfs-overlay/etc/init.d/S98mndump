#!/bin/sh
# ---------------------------------------------------------------------------
# FORK A warm-chain test (2026-07-03). wg_warm_chain=1: within one whole-graph
# job, the FIRST kick (conv0) runs pp_state_init to engage, and the re-kicks
# (task 1..N) SKIP it -- so the ping-pong pointers stay where the previous task
# left them and the on-chip CBUF stays warm across layers instead of being
# cleared (POINTER_PP_CLEAR) between kicks. Each task's regcmd arms its own
# S_POINTER, so the first kick's pp_state_init is enough for engage.
#   chained-layer output distinct>1 (reads the warm CBUF the prev layer wrote) +
#     Top-1 near CPU 412 = keeping CBUF warm across kicks carries the chain. WIN.
#   chained still distinct=1 = the inter-kick teardown that cools CBUF is NOT
#     (only) pp_state_init -> next lever = the OP_EN 1->0 cycle / the ~30us gap.
# perjob_ppinit=1 (first kick still arms). force_powercycle not on this branch.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "warmchain: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null
	echo 0 > /sys/module/rocket/parameters/cbuf_reset 2>/dev/null
	echo -1 > /sys/module/rocket/parameters/enable_mask 2>/dev/null
	echo 0 > /sys/module/rocket/parameters/multitask_poll 2>/dev/null
	echo 1 > /sys/module/rocket/parameters/perjob_ppinit 2>/dev/null
	echo 1 > /sys/module/rocket/parameters/wg_warm_chain 2>/dev/null

	dmesg -c >/dev/null 2>&1
	log ""
	log "===== FORK A: wg_warm_chain=1 (first kick arms, re-kicks keep CBUF warm) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1
	log "---- exec_ever + per-task output distinct + perf (chained compute?) ----"
	dmesg | grep -aE "rocket dbg exec: ever_bit16|rocket dbg buf\[[1-6]\] out task=|rocket dbg perf:" | grep -avE "@0x|cover|fine" | head -30 > "$C" 2>&1
	log "===== DONE: chained distinct>1 = warm-CBUF-across-kicks carries the chain ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
