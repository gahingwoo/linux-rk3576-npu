#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 open_high A/B (2026-07-04). Position is the gate (conv0_twice: 2nd conv0
# core dt_wr=63 vs 25088). RK3588-vs-RK3576 diff: the ONLY per-kick deviation is
# our seq-kick pulsing PC OP_EN 1->0 AT SUBMIT (OP_EN=0 during execution), vs
# upstream leaving OP_EN HIGH through execution and clearing at completion.
# open_high tests that: leave OP_EN high, complete on DPU-done (bits 8/9), and a
# 300ms poll cap is the unconditional safety net (no hang -> reset -> iommu death).
#   Regime: seq-kick (WHOLE_GRAPH, wg_continuous=0) + warm_chain=1.
#   ORACLE = per-task "rocket dbg perf: ... core[dt_wr=..]" (NOT distinct -- stale).
#   RUN A  open_high=0 (baseline): conv0 core dt_wr~25088, dw1 (task1) dt_wr~63.
#   RUN B  open_high=1 (THE TEST): watch dw1+later tasks' core dt_wr.
#            - dt_wr >> 63 (thousands) for task>=1 => OP_EN-high was the per-task
#              arm. Then check infer.py Top-1.
#            - dt_wr still ~0/63 => last software-structural diff ruled out; arm is
#              below sw level (NVDLA CSC/CMAC RTL / RK3576 quirk).
#            - "seq-kick poll TIMEOUT" lines => report OP_EN/PC_DONE at cap (did the
#              DPU-done completion take over?).
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "open_high: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	# ---- regime: seq-kick + warm-chain ----
	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 0 > $P/bisect 2>/dev/null
	echo 0 > $P/rekick_reset 2>/dev/null
	echo 1 > $P/wg_warm_chain 2>/dev/null
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	echo 0 > $P/chain_task_number 2>/dev/null
	echo 0 > $P/geom_both 2>/dev/null
	echo 0 > $P/geom_all 2>/dev/null
	echo 0 > $P/conv0_twice 2>/dev/null
	echo 0 > $P/audit_all 2>/dev/null
	echo 0 > $P/audit_arm 2>/dev/null

	# ---- RUN A: open_high=0 (baseline) ----
	echo 0 > $P/open_high 2>/dev/null
	dmesg -c >/dev/null 2>&1
	log ""
	log "===== OPEN_HIGH RUN A: open_high=0 (baseline submit-pulse) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	# ---- RUN B: open_high=1 (THE TEST) ----
	echo 1 > $P/open_high 2>/dev/null
	log ""
	log "===== OPEN_HIGH RUN B: open_high=1 (OP_EN high, DPU-done completion) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	log "===== OPEN_HIGH DONE: compare per-task core[dt_wr] A vs B; dw1 dt_wr>>63 in B = OP_EN-high armed it ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
