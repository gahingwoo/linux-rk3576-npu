#!/bin/sh
# ---------------------------------------------------------------------------
# PATH 1+2 on the RIGHT target (2026-07-03): the natural per-op multi-task dw
# ALREADY engages (ever_bit16=0xf) -- its wall is CBUF-stale, not engage. The
# REAL multi-task ENGAGE wall (exec_ever=0x0) is the WHOLE-GRAPH path (one job,
# task_count=~29, PC iterates but units never engage). Test the NVDLA reverse
# op_enable order THERE: ROCKET_WHOLE_GRAPH=1 + ROCKET_REV_OPEN=1. Whole-graph
# also chains layers via CBUF, so if the units engage the whole net computes.
#   exec_ever 0x0 -> 0xf (+ Top-1 near CPU's 653) -> reverse op_enable cracks the
#     whole-graph engage wall -> MobileNet end-to-end.
#   exec_ever still 0x0 -> order isn't the WG-engage lever either.
# multitask_poll=0 (first PC_DONE) so a stalled WG PC cannot hang the board.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "wg: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null
	echo 0 > /sys/module/rocket/parameters/cbuf_reset 2>/dev/null
	echo -1 > /sys/module/rocket/parameters/enable_mask 2>/dev/null
	echo 0 > /sys/module/rocket/parameters/multitask_poll 2>/dev/null
	echo 1 > /sys/module/rocket/parameters/wg_open 2>/dev/null
	echo 1 > /sys/module/rocket/parameters/perjob_ppinit 2>/dev/null
	for f in $(find /sys/devices -path '*npu*/power/control' 2>/dev/null); do echo on > "$f" 2>/dev/null; done
	for f in $(find /sys/devices -path '*npu*/power/autosuspend_delay_ms' 2>/dev/null); do echo 120000 > "$f" 2>/dev/null; done

	dmesg -c >/dev/null 2>&1
	log ""
	log "===== WG + REV_OPEN + perjob_ppinit=1 (ARM S_POINTER, removes the unarmed confound) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 ROCKET_REV_OPEN=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1
	log "---- WG engage: exec_ever + wgsubmit(task_count/DATA_ADDR) + buf out + perf ----"
	dmesg | grep -aE "rocket dbg exec: ever_bit16|rocket dbg wgsubmit|rocket dbg buf\[[1-4]\] out task=0 |rocket dbg perf:" | grep -avE "@0x|cover|fine" | head -12 > "$C" 2>&1
	log "===== DONE: exec_ever=0xf + Top-1~653 = WG engage cracked -> MobileNet end-to-end ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
