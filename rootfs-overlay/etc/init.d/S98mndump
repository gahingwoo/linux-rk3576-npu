#!/bin/sh
# ---------------------------------------------------------------------------
# FORK A diagnostic (2026-07-03): does the per-job CBUF-A reset corrupt ANY
# compute, or only the chain? Run a SINGLE conv (conv2d-cal, byte-exact vs CPU
# without any reset) through mesa with rocket.cbuf_reset=2 and read the maxdiff
# oracle (test_conv.py: NPU vs CPU byte-for-byte). No chain, no ONEJOB, no
# enable_mask -> cannot hang.
#   maxdiff small (~1) -> the reset is fine for a lone single-task compute; the
#     chain saturation is chain-context-specific (reset timing vs the chained DMA).
#   maxdiff large / output 0x7f -> the CBUF-A reset corrupts ANY compute (CORE
#     left inconsistent) -> the fix must make the reset non-corrupting (CORE
#     re-init after reset), a kernel change.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { echo "forka: no accel device" > "$C"; return 0; }
	dmesg -n 8 2>/dev/null
	echo -1 > /sys/module/rocket/parameters/enable_mask 2>/dev/null   # OFF (it wedges)
	echo 0 > /sys/module/rocket/parameters/multitask_poll 2>/dev/null
	echo 2 > /sys/module/rocket/parameters/cbuf_reset 2>/dev/null     # the variable under test
	for f in $(find /sys/devices -path '*npu*/power/control' 2>/dev/null); do echo on > "$f" 2>/dev/null; done

	dmesg -c >/dev/null 2>&1
	echo "" > "$C"
	echo "===== FORK A diag: single conv2d-cal + cbuf_reset=2 -- does the reset corrupt a lone compute? =====" > "$C"
	env TEFLON_LIB=/usr/lib/libteflon.so TEFLON_DEBUG=1 \
		python3 "$NPU_DIR/test_conv.py" "$NPU_DIR/conv2d-cal.tflite" > "$C" 2>&1
	echo "---- output bytes (0x7f/0x80 = saturated; rich = correct) + perf ----" > "$C"
	dmesg | grep -aE "rocket dbg buf\[[1-4]\] out task=0 |rocket dbg perf:|cbuf_reset:" | grep -avE "cover|fine|@0x" | head -6 > "$C" 2>&1
	echo "===== DONE: maxdiff small = reset OK for single-task; maxdiff large = reset corrupts any compute =====" > "$C"
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
