#!/bin/sh
# ---------------------------------------------------------------------------
# FORK A engage x dispatch matrix (2026-07-04 v2). The prior A/B set STRIP_OPEN=1
# on both runs -> both dead: STRIP_OPEN removes the in-stream 0x81 op_en (writes
# ENABLE_MASK 0xf008=0x1d) that is what actually engages OUR units, so exec_ever=0.
# The known-good sequential/warm-chain run (66c1303) used ROCKET_WHOLE_GRAPH=1 with
# NO STRIP_OPEN. So sweep the real matrix, one boot, 3 inferences:
#   RUN 1  seq  + in-stream op_en  -> KNOWN GOOD: exec_ever=0xf, conv0 distinct=239
#                                     (sanity: build is fine, engage intact).
#   RUN 2  cont + in-stream op_en  -> THE CRUX. task_number=29, units SHOULD engage
#                                     (exec_ever=0xf). Watch the "multitask %u/29"
#                                     climb + task-0 cnalive/perf:
#                                       TASK_STATUS 0->29 = PC iterates (JACKPOT).
#                                       stuck 0 w/ exec_ever=0xf = units engage,
#                                         task 0 never completes its DPU write
#                                         (the register/microcode wall) OR the
#                                         in-stream 0x1d restarts the PC each task.
#   RUN 3  cont + STRIP_OPEN        -> contrast (last boot's data): exec_ever=0,
#                                     TASK_STATUS stuck 1. Same-boot so no drift.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "forkA: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 1 > $P/wg_warm_chain 2>/dev/null

	# ---- RUN 1: sequential kick + in-stream op_en (KNOWN-GOOD baseline) ----
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	dmesg -c >/dev/null 2>&1
	log ""
	log "===== FORK A RUN 1: seq + in-stream op_en (baseline exec_ever=0xf) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	# ---- RUN 2: continuous submit task_number=N + in-stream op_en (THE CRUX) ----
	echo 1 > $P/multitask_poll 2>/dev/null
	echo 1 > $P/wg_continuous 2>/dev/null
	log ""
	log "===== FORK A RUN 2: continuous + in-stream op_en (crux: engage vs complete) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	# ---- RUN 3: continuous submit + STRIP_OPEN (contrast, same boot) ----
	log ""
	log "===== FORK A RUN 3: continuous + STRIP_OPEN (contrast, no-engage) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 ROCKET_STRIP_OPEN=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	log "===== FORK A DONE: RUN1 engages+computes; RUN2 = does task_number=N engage AND advance? ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
