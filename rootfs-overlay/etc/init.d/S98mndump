#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 NEXT-POINTER experiment (2026-07-04). Port RK3588's embedded next-pointer
# self-chaining to RK3576: mesa (ROCKET_NEXTPTR) now emits the RK3588-style trailer
# (PC BASE_ADDRESS 0x10 + REGISTER_AMOUNTS 0x14) at the end of every task and the
# whole-graph packer chains each task to the next. The kernel runs the RK3588-style
# dispatch (wg_continuous = task_number=N, one OP_EN); if the RK3576 PC follows the
# trailer, one kick walks the whole graph with each task in the committing mode,
# instead of the task_number iteration that walls (only the cold-start task commits).
#   RUN 1  baseline sequential-kick, NO next-pointer -> the known state: conv0
#          (feb2d000) computes (core dt_wr=25088, distinct=239); dw1 (fea69000) and
#          later layers dt_wr=0, distinct=1.
#   RUN 2  NEXT-POINTER (wg_continuous + multitask_poll + ROCKET_NEXTPTR) = THE TEST:
#          do tasks AFTER conv0 now show core dt_wr>0 and output distinct>1?
#            dw1 distinct>1 / dt_wr>0 = the RK3576 PC FOLLOWS next-pointers -> the
#              chain computes ->穿墙.
#            dw1 still distinct=1 / dt_wr=0 = the PC does NOT follow next-pointers ->
#              iteration is the only path and the wall is silicon.
# Watch the "multitask %u/29" climb + per-task perf(core dt_wr) + buf out distinct.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "nextptr: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 0 > $P/bisect 2>/dev/null
	echo 0 > $P/rekick_reset 2>/dev/null
	echo 1 > $P/wg_warm_chain 2>/dev/null

	# ---- RUN 1: baseline sequential-kick, no next-pointer ----
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	dmesg -c >/dev/null 2>&1
	log ""
	log "===== NEXTPTR RUN 1: baseline seq-kick (no next-pointer) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	# ---- RUN 2: next-pointer chain (RK3588 mechanism on RK3576) ----
	echo 1 > $P/multitask_poll 2>/dev/null
	echo 1 > $P/wg_continuous 2>/dev/null
	log ""
	log "===== NEXTPTR RUN 2: next-pointer chain (wg_continuous + ROCKET_NEXTPTR) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 ROCKET_NEXTPTR=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	log "===== NEXTPTR DONE: RUN2 dw1(fea69000) dt_wr>0/distinct>1 = PC follows next-pointers ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
