#!/bin/sh
# ---------------------------------------------------------------------------
# FORK A UNIT_OPEN sweep (2026-07-04 v3). Research nailed the untested lever:
# mesa's default (non-STRIP) whole-graph path already replaces the broadcast
# op_en (which wedges the PC via reg 0x08) with FOUR per-unit OP_EN writes
# (CNA 0x1008 / CORE 0x3008 / DPU 0x4008 / RDMA 0x5008) that DON'T touch the PC.
# Prior data: per-unit value 0x1 engages the CNA (conv0 dt_rd=9408) but the task
# never COMPLETES (core dt_wr=0, TASK_STATUS stuck 1/29). The broadcast that DOES
# complete writes 0x1d (the RKNPU enable_mask). So the hypothesis (mesa comment's
# own): per-unit value 0x1d gives the units the FULL enable the broadcast gives,
# WITHOUT touching the PC's 0x08 -> units complete AND the PC iterates. Pure env
# test (deployed libteflon has ROCKET_UNIT_OPEN); wg_continuous=1 = one PC submit.
#   RUN 1  seq baseline (sanity: exec_ever=0xf, conv0 distinct=239).
#   RUN 2  continuous + UNIT_OPEN=0x1d = THE HYPOTHESIS. Watch "multitask %u/29":
#            climbs 1->29 = units complete, PC iterates (JACKPOT); stuck 1 = 0x1d
#            doesn't drive completion either -> completion is task_number-gated,
#            not an op_en-value thing.
#   RUN 3  continuous + UNIT_OPEN=0x1 = control (reproduce the 1/29 stall).
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "forkA: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 1 > $P/wg_warm_chain 2>/dev/null

	# ---- RUN 1: sequential baseline (sanity) ----
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	dmesg -c >/dev/null 2>&1
	log ""
	log "===== FORK A RUN 1: seq baseline (exec_ever=0xf, distinct=239) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	# ---- RUN 2: continuous + per-unit OP_EN = 0x1d (THE HYPOTHESIS) ----
	echo 1 > $P/multitask_poll 2>/dev/null
	echo 1 > $P/wg_continuous 2>/dev/null
	log ""
	log "===== FORK A RUN 2: continuous + ROCKET_UNIT_OPEN=0x1d (full per-unit enable) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 ROCKET_UNIT_OPEN=0x1d \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	# ---- RUN 3: continuous + per-unit OP_EN = 0x1 (control, 1/29 stall) ----
	log ""
	log "===== FORK A RUN 3: continuous + ROCKET_UNIT_OPEN=0x1 (control) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 ROCKET_UNIT_OPEN=0x1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	log "===== FORK A DONE: RUN2 (0x1d) TASK_STATUS climb past 1 = units complete + PC iterates ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
