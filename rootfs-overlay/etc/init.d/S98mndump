#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 CBUF audit_all (2026-07-04). geom_both refuted config-latch: dw1's real
# config forced into both PP-groups still MACs zero. The only stage between the
# CNA DMA and the CMAC is the CBUF, so the break is CNA->CBUF (dw1's operands
# never land in the CBUF bank the CMAC reads) or CBUF->CSC->CMAC (in CBUF, CSC
# never consumes). rocket.audit_all dumps a per-task CBUF snapshot (16x64KB
# windows, PRE + POST-with-changed-windows) plus each layer's CBUF_CON regcmd
# decode -- for EVERY kick, so dw1 (out=0xfea69000) is captured, not just conv0.
#   Regime: seq-kick (WHOLE_GRAPH, wg_continuous=0) + warm_chain=1 = dw1 reads
#   its input (dt_rd=20384).
#   WATCH per task "out=0x........":
#     - conv0 out=0xfeb2d000: POST changed[...] non-empty (data staged, computes).
#     - dw1   out=0xfea69000: POST changed[...] ==>
#         * non-empty  => dw1's data DID reach CBUF -> break is CBUF->CMAC (CSC
#           never consumed) -> NBUF ruled out, pivot CSC/CMAC arm.
#         * empty [none] => dw1's data NEVER staged -> break is CNA->CBUF ->
#           CNA->CBUF write is the cold-start-gated step (NBUF/bank re-arm).
#     - CBUF_CON regcmd DBANK/DENTRIES conv0 vs dw1: does bank alloc differ.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "cbuf-audit: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	# ---- regime: seq-kick + warm-chain (dw1 reads its input here) ----
	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 0 > $P/bisect 2>/dev/null
	echo 0 > $P/rekick_reset 2>/dev/null
	echo 1 > $P/wg_warm_chain 2>/dev/null
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	echo 0 > $P/chain_task_number 2>/dev/null
	echo 0 > $P/geom_both 2>/dev/null

	# ---- CBUF audit for EVERY kick (per-task snapshots incl. dw1) ----
	echo 0 > $P/audit_arm 2>/dev/null
	echo 1 > $P/audit_all 2>/dev/null

	dmesg -c >/dev/null 2>&1
	log ""
	log "===== CBUF-AUDIT: seq-kick, audit_all=1 (per-task CBUF PRE/POST) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	log "===== CBUF-AUDIT DONE: match out=0xfea69000 (dw1) POST changed[...] -> CNA->CBUF vs CBUF->CMAC ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
