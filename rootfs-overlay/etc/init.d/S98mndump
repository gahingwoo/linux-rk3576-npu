#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 conv0_twice (2026-07-04). geom_all closed the regcmd-register line; the
# RK3588-vs-RK3576 diff shows the per-task register sequence is byte-identical,
# so the chained-layer wall is a cold-start internal CONTEXT (position), not a
# register. conv0_twice nails position directly: after the whole seq-kick job
# completes, re-run task 0 (conv0) ONE more time with NO reset/re-init, then
# finalise. Same regcmd + same external input; only difference = it is no longer
# the first-task-after-NPU-init.
#   Regime: seq-kick (WHOLE_GRAPH, wg_continuous=0) + warm_chain=1.
#   WATCH the LAST "out task=0 iova=0xfeb2d000" line (right after the log line
#   "rocket conv0_twice: re-running task 0"):
#     - 2nd conv0 distinct=1 (1st was ~240) => PURE POSITION: the arm is consumed
#       by the first-after-init task, independent of layer/data. Decisive.
#     - 2nd conv0 still ~240 => position is NOT the gate; something else re-arms.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "conv0_twice: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	# ---- regime: seq-kick + warm-chain ----
	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 0 > $P/bisect 2>/dev/null
	echo 0 > $P/rekick_reset 2>/dev/null
	echo 1 > $P/wg_warm_chain 2>/dev/null
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	echo 0 > $P/chain_task_number 2>/dev/null
	echo 0 > $P/geom_both 2>/dev/null
	echo 0 > $P/geom_all 2>/dev/null
	echo 0 > $P/audit_all 2>/dev/null
	echo 0 > $P/audit_arm 2>/dev/null

	echo 1 > $P/conv0_twice 2>/dev/null
	dmesg -c >/dev/null 2>&1
	log ""
	log "===== CONV0_TWICE: seq-kick, re-run task 0 after job completes ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_WHOLE_GRAPH=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	log "===== CONV0_TWICE DONE: last 'out task=0 0xfeb2d000' (after 're-running task 0') distinct=1 = PURE POSITION ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
