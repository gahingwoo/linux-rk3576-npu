#!/bin/sh
# ---------------------------------------------------------------------------
# THE REAL TEST (2026-07-03): the chain replay PROVED the conv0->dw dt_rd=0 is
# STALE CBUF (chained layer reuses conv0's leftover CBUF entries instead of
# re-DMAing from DRAM), and rocket.cbuf_reset=2 (A+H CBUF reset per job) FIXED it
# (chained layers went dt_rd=0 -> dt_rd>0, computed). Now apply it to the ACTUAL
# mesa Path B MobileNet: ROCKET_TILE_JOBS + ROCKET_TILE_SPTR=0xe (vendor dw
# S_POINTER) + rocket.cbuf_reset=2. If dw1 (buf[3]) computes -> end-to-end
# MobileNet via Path B is unblocked.
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "pathb: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null
	echo 0 > /sys/module/rocket/parameters/audit_arm 2>/dev/null
	echo 1 > /sys/module/rocket/parameters/multitask_poll 2>/dev/null
	echo 6 > /sys/module/rocket/parameters/cbuf_reset 2>/dev/null
	for f in $(find /sys/devices -path '*npu*/power/control' 2>/dev/null); do echo on > "$f" 2>/dev/null; done
	for f in $(find /sys/devices -path '*npu*/power/autosuspend_delay_ms' 2>/dev/null); do echo 120000 > "$f" 2>/dev/null; done

	dmesg -c >/dev/null 2>&1
	log ""
	log "===== Path B MobileNet + cbuf_reset=2 (TILE_JOBS + TILE_SPTR=0xe) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_TILE_JOBS=1 ROCKET_TILE_CBUF=1 ROCKET_TILE_SPTR=0xe \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1
	log "---- per-layer buf out (buf[1]=conv0, buf[3]=dw1 = the depthwise) ----"
	dmesg | grep -E "rocket dbg buf\[[1-8]\] out task=0 " | grep -vE "@0x|cover|fine" > "$C" 2>&1
	log "---- perf (top dt_rd = CNA DRAM read per layer) ----"
	dmesg | grep -E "rocket dbg perf:" | head -8 > "$C" 2>&1
	log "===== DONE: buf[3] (dw1) distinct + Top-1 vs CPU (653) ====="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
