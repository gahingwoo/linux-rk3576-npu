#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 NPU — CORRECTNESS oracle (byte-for-byte NPU vs CPU), not a distinct count.
#
# The whole prior campaign chased `distinct` on conv2d.tflite. That metric is
# invalid: conv2d.tflite is synthetic and its CORRECT int8 output SATURATES
# (CPU reference: distinct~5, 100% pinned to 0x7f/0x80), so a correct conv and a
# broken constant-fill BOTH give distinct<=2 -- indistinguishable. And the output
# "head" is structure-invariant (shuffled/wrong weights yield the same head), so
# head can't judge either. Two blind metrics => no oracle.
#
# Fix: test against conv2d-cal.tflite (out_sc=32, out_zp=128) whose CORRECT output
# is a RICH non-saturated map (distinct~256), and judge by MAXDIFF vs the CPU
# tflite reference (test_conv.py). maxdiff<=2 = correct (int8 rounding); maxdiff
# large = the real bug, now localizable to actual pixels.
#
# test_conv.py runs teflon (NPU) AND tflite_runtime (CPU) on the same input and
# diffs them. TEFLON_DEBUG=1 prints the delegated-node count so a silent CPU
# fallback (which would fake maxdiff=0) is visible in the log.
#
# Run the CALIBRATED (discriminating) model FIRST -- the board's drm_mm_takedown
# bug can wedge BO cleanup after ~1-2 submits, so the decisive test must run first.
# ---------------------------------------------------------------------------

NPU_DIR=/opt/npu-test
C=/dev/console
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "npu-test: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null
	dmesg -c >/dev/null 2>&1
	# Silence the per-job CNAREG/cnalive kernel dump; it floods serial and can
	# wedge the board before the userspace RESULT line prints.
	echo 0 > /sys/module/rocket/parameters/audit_arm 2>/dev/null

	# Keep the NPU powered through the test. The post-job autosuspend (pm_runtime_put
	# _autosuspend) races the userspace maxdiff print: when it wins, the genpd powers
	# the NPU off, 'nputop' fails to idle, cpu voltage times out (-110) and the board
	# wedges before the verdict prints. Force runtime PM off (device stays active ->
	# domains stay on) so the print always wins. (1) unblock = read the real maxdiff.
	find /sys/devices -path '*npu*/power/control' 2>/dev/null | while read f; do
		echo on > "$f" 2>/dev/null
	done
	find /sys/devices -path '*27700000.npu*/power/control' 2>/dev/null | while read f; do
		echo on > "$f" 2>/dev/null
	done
	find /sys/devices -path '*npu*/power/autosuspend_delay_ms' 2>/dev/null | while read f; do
		echo 120000 > "$f" 2>/dev/null
	done

	export TEFLON_LIB=/usr/lib/libteflon.so
	export TEFLON_DEBUG=1
	# Broadcast op_en writes the global ENABLE_MASK (0xf008) -> teflon engages
	# (exec_ever=0xf in every broadcast run). The earlier degeneracy was the BIAS,
	# now fixed in rkt_coefs.c. ORACLE = test_conv.py maxdiff (NOT core wt_rd, a red
	# herring -- the computing run showed wt_rd=0 too).
	export ROCKET_BCAST_OPEN=1

	# BISECT the error (maxdiff now readable). Segment 1 is the clean one (the 2nd
	# submit degenerates from board state). H-myfloat = vendor A/B/C + MY dense float:
	# small maxdiff => my float reconstruction is OK and A/B/C is the error. H-myABC =
	# MY A/B/C + vendor float: small => A/B/C OK, float is the error.
	# STRUCTURE vs VALUES (float surface). H-shuf = vendor float STRUCTURE (mask) with
	# the nonzero VALUES shuffled. If maxdiff stays small -> only the sparse structure
	# matters, values are tolerant -> derive the mask, fill anything. If large -> the
	# exact values matter (toolkit-blob). H-structconst = structure + one constant.
	log ""
	log "########## (1) H-shuf: vendor structure, SHUFFLED float values (structure vs values) ##########"
	env ROCKET_BIAS_FILE="$NPU_DIR/H-shuf.bin" \
		python3 "$NPU_DIR/test_conv.py" "$NPU_DIR/conv2d-cal.tflite" > "$C" 2>&1

	log ""
	log "########## (2) H-structconst: vendor structure, CONSTANT values (2nd submit, may degenerate) ##########"
	env ROCKET_BIAS_FILE="$NPU_DIR/H-structconst.bin" \
		python3 "$NPU_DIR/test_conv.py" "$NPU_DIR/conv2d-cal.tflite" > "$C" 2>&1

	log ""
	log "########## END structure-vs-values test (read segment 1 maxdiff) ##########"
	log ""
}

case "$1" in
	start) start ;;
	stop) : ;;
	restart) start ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
