#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 NPU — CORRECTNESS oracle (byte-for-byte NPU vs CPU), not a distinct count.
#
# The whole prior campaign chased `distinct` on conv2d.tflite. That metric is
# invalid: conv2d.tflite is synthetic and its CORRECT int8 output SATURATES
# (CPU reference: distinct~5, 100% pinned to 0x7f/0x80), so a correct conv and a
# broken constant-fill BOTH give distinct<=2 -- indistinguishable. And the output
# "head" is structure-invariant (shuffled/wrong weights yield the same head), so
# head can't judge either. Two blind metrics => no oracle.
#
# Fix: test against conv2d-cal.tflite (out_sc=32, out_zp=128) whose CORRECT output
# is a RICH non-saturated map (distinct~256), and judge by MAXDIFF vs the CPU
# tflite reference (test_conv.py). maxdiff<=2 = correct (int8 rounding); maxdiff
# large = the real bug, now localizable to actual pixels.
#
# test_conv.py runs teflon (NPU) AND tflite_runtime (CPU) on the same input and
# diffs them. TEFLON_DEBUG=1 prints the delegated-node count so a silent CPU
# fallback (which would fake maxdiff=0) is visible in the log.
#
# Run the CALIBRATED (discriminating) model FIRST -- the board's drm_mm_takedown
# bug can wedge BO cleanup after ~1-2 submits, so the decisive test must run first.
# ---------------------------------------------------------------------------

NPU_DIR=/opt/npu-test
C=/dev/console
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "npu-test: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null
	dmesg -c >/dev/null 2>&1
	# Silence the per-job CNAREG/cnalive kernel dump; it floods serial and can
	# wedge the board before the userspace RESULT line prints.
	echo 0 > /sys/module/rocket/parameters/audit_arm 2>/dev/null

	# Keep the NPU powered through the test. The post-job autosuspend (pm_runtime_put
	# _autosuspend) races the userspace maxdiff print: when it wins, the genpd powers
	# the NPU off, 'nputop' fails to idle, cpu voltage times out (-110) and the board
	# wedges before the verdict prints. Force runtime PM off (device stays active ->
	# domains stay on) so the print always wins. (1) unblock = read the real maxdiff.
	find /sys/devices -path '*npu*/power/control' 2>/dev/null | while read f; do
		echo on > "$f" 2>/dev/null
	done
	find /sys/devices -path '*27700000.npu*/power/control' 2>/dev/null | while read f; do
		echo on > "$f" 2>/dev/null
	done
	find /sys/devices -path '*npu*/power/autosuspend_delay_ms' 2>/dev/null | while read f; do
		echo 120000 > "$f" 2>/dev/null
	done

	export TEFLON_LIB=/usr/lib/libteflon.so
	export TEFLON_DEBUG=1
	# Broadcast op_en writes the global ENABLE_MASK (0xf008) -> teflon engages
	# (exec_ever=0xf in every broadcast run). The earlier degeneracy was the BIAS,
	# now fixed in rkt_coefs.c. ORACLE = test_conv.py maxdiff (NOT core wt_rd, a red
	# herring -- the computing run showed wt_rd=0 too).
	export ROCKET_BCAST_OPEN=1

	# BISECT the error (maxdiff now readable). Segment 1 is the clean one (the 2nd
	# submit degenerates from board state). H-myfloat = vendor A/B/C + MY dense float:
	# small maxdiff => my float reconstruction is OK and A/B/C is the error. H-myABC =
	# MY A/B/C + vendor float: small => A/B/C OK, float is the error.
	# STRUCTURE vs VALUES (float surface). H-shuf = vendor float STRUCTURE (mask) with
	# the nonzero VALUES shuffled. If maxdiff stays small -> only the sparse structure
	# matters, values are tolerant -> derive the mask, fill anything. If large -> the
	# exact values matter (toolkit-blob). H-structconst = structure + one constant.
	# PIVOT TEST: is the vendor's value-dependent weight placement load-bearing, or
	# just an optimization a derivable encoder can ignore?
	#  (1) H-shufW = vendor buffer, ONLY the weight-scatter slots shuffled among
	#      themselves (skeleton/ABC/structural byte-identical). maxdiff small => the
	#      value-to-slot assignment does NOT matter -> derive the mask, fill any order
	#      -> the surface is DERIVABLE. maxdiff large => placement is load-bearing.
	#  (2) plain-OIHW = weight slots refilled in plain OIHW order (a specific derivable
	#      layout). Runs 2nd (board may wedge after 1-2 submits, so the decisive one is 1st).
	# DIAGNOSE zero-rail = wrong COEFFICIENTS vs not ENGAGED. Control variable = the
	# regcmd: A and B use the SAME RK3576 regcmd (same op_en/engage), differing ONLY in
	# the coefficient BYTES. So whatever engage state A has, B has.
	#   A (engage control): vendor bytes -> distinct=256 PROVES engage works (a rich
	#     output requires the conv to actually run). Read exec_ever (1=CNA 2=CORE 4=DPU
	#     8=RDMA; 0xf=all engaged) in the cnalive dump.
	#   B (coef test): mesa-generated ABC, same regcmd. If A engaged (256) and B=distinct1
	#     zero-rail -> SAME engage, so the zero-rail is the COEFFICIENTS, not engage.
	# readback_delay_ms makes the post-job register/output reads reliable (not timing-confounded).
	# OUT_CVT shift FINE-SWEEP, one value per BOOT (fresh first submit -> avoids the
	# 2nd-submit/drm_mm_takedown degradation). A persistent counter on the rw rootfs
	# picks the next shift each boot. Branch-1 (requant crush) is confirmed; this finds
	# the shift where the output is RICH and CORRECT. ORACLE = maxdiff (NOT distinct:
	# distinct is low both when crushed AND when saturated). Watch maxdiff bottom out.
	#   FLASH ONCE, then REBOOT (no reflash) to step through the sweep. Delete
	#   /opt/npu-test/sweep_idx to restart.
	# BIAS-FORMULA variant scan, one variant per BOOT (fresh first submit). The per-channel
	# A=0x80*(sw+bias) term is the bug (A>0 channels saturate, tracking sign(sw+bias)).
	# For in_zp=0x80 the sw correction should be 0, so `sw` may be spurious. ORACLE = maxdiff.
	#   1 V1: ROCKET_BIAS_NOSW   -> A=0x80*bias_in          (drop sw -- TEST FIRST, most likely)
	#   2 V2: ROCKET_BIAS_NOSCALE-> A=1*(sw+bias_in)        (drop 0x80)
	#   3 V3: both               -> A=bias_in (Tomeu RK3588 in_zp=0x80 form)
	#   4 baseline (no env)      -> A=0x80*(sw+bias_in)
	# FLASH ONCE, then REBOOT to step. rm /opt/npu-test/sweep_idx to restart.
	# V3 (A=bias_in, the per-channel fix) is LOCKED; now sweep the OUT_CVT offset to
	# re-align the residual +0x80 (output clips at min=out_zp, negative half lost).
	# Judge by MAXDIFF *and* whether min un-clips toward 0 (the negative half returns).
	IDX=/opt/npu-test/sweep_idx
	i=$(cat "$IDX" 2>/dev/null || echo 0)
	echo $((i + 1)) > "$IDX"; sync
	echo 50 > /sys/module/rocket/parameters/readback_delay_ms 2>/dev/null
	# V3 + offset=-128 LOCKED (centering confirmed: min=0, mean=127). Now compress the
	# too-wide spread: sweep shift_add up. Watch maxdiff bottom out AND NPU_sat -> 0
	# (un-saturate). If maxdiff hits single digits + sat~0 -> BYTE-EXACT, closed.
	# If maxdiff bottoms ~30-50 with residual sat -> a B/C per-pixel/channel term left.
	# BS_OW_OP (the missing wt_zp per-pixel correction) is the root cause of bug 3.
	# With it set, the wt_zp spread is corrected -> A should be plain bias_in (V3) and
	# the offset should be the computed one (the earlier offset=-128 was compensating
	# for the missing correction's DC). Boot 1 = the principled byte-exact candidate.
	# ROOT CAUSE PROVEN OFFLINE: the wt_zp correction lives in the WEIGHT PACKING,
	# not any register (vendor regcmd sets NO BS_OW_OP/BS_CFG -- byte-identical to mesa).
	# Pack w-wt_zp (ROCKET_WT_ZP) -> CMAC computes the true conv per pixel. Offline this
	# reproduces the tflite CPU reference BYTE-FOR-BYTE (first8 [119,136,164,113,...]).
	# Pair with V3 (A=plain bias_in; in_zp=0x80 so the sw/correction term is 0) and the
	# computed offset. Boot 1 = the proven byte-exact config.
	# BS_CFG/BS_OW_OP writes were INERT (those regs likely don't exist on RK3576). The
	# board mishandles the LARGE signed accumulator (|acc|~2e5; acc*cvt_scale~6.7e9
	# OVERFLOWS int32). DECISIVE TEST: confine the input to in_zp +/- TEST_INAMP so |acc|
	# stays small (no int32 overflow). If the NPU matches CPU at small amp but diverges
	# as amp grows -> the requant fixed-point multiply is overflowing. Also gives the
	# first CLEAN w-0x80 vs w-wt_zp comparison (no overflow masking). maxdiff is the oracle.
	V3="ROCKET_BIAS_NOSW=1 ROCKET_BIAS_NOSCALE=1"
	case "$i" in
		0) V="INAMP=1 + V3 + w-0x80 (tiny acc, no overflow)"; E="TEST_INAMP=1 $V3" ;;
		1) V="INAMP=1 + V3 + WT_ZP (tiny acc, w-wt_zp)";       E="TEST_INAMP=1 ROCKET_WT_ZP=1 $V3" ;;
		2) V="INAMP=4 + V3 + w-0x80 (small acc)";              E="TEST_INAMP=4 $V3" ;;
		3) V="INAMP=16 + V3 + w-0x80 (medium acc)";            E="TEST_INAMP=16 $V3" ;;
		*) log "########## INAMP SCAN DONE (rm $IDX to restart) ##########"; V="" ;;
	esac
	if [ -n "$V" ]; then
		log ""
		log "########## bias variant boot $((i + 1)): $V [$E] -- judge by MAXDIFF ##########"
		env $E python3 "$NPU_DIR/test_conv.py" "$NPU_DIR/conv2d-cal.tflite" > "$C" 2>&1
		log "########## END $V -- REBOOT for next variant ##########"
	fi
	log ""
}

case "$1" in
	start) start ;;
	stop) : ;;
	restart) start ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
