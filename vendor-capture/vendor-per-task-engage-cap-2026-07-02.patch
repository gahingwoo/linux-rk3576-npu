+/*
+ * CAPTURE-FULL: store the COMPLETE payload (regcmd + input + weights + bias) the
+ * vendor submits for the simplest conv into /proc/rknpu_cap, for byte-exact
+ * replay through both the rknn and rocket UABIs (flipper #55, Tomeu's method).
+ * Framed TLV: [magic "RKC1"] then per section [tag u32][iova u32][len u32][bytes].
+ *
+ * Reads each BO PAGE BY PAGE: the regcmd's address is one IOVA, but a BO spans
+ * many pages that the IOMMU maps to scattered physical pages, so each page's
+ * iova must be translated separately (a flat phys read past page 0 would grab
+ * physically-adjacent memory, not the BO's next page).
+ */
+#define RKNPU_CAP_MAGIC   0x31434b52      /* "RKC1" */
+#define RKNPU_CAP_TAG_RGC 0x44434752      /* "RGCD" regcmd  */
+#define RKNPU_CAP_TAG_IN  0x54504e49      /* "INPT" input   */
+#define RKNPU_CAP_TAG_WT  0x54484757      /* "WGHT" weights */
+#define RKNPU_CAP_TAG_BS  0x53414942      /* "BIAS" bias    */
+#define RKNPU_CAP_MAX     (2u << 20)      /* 2 MiB */
+
+static u8 *rknpu_cap_buf;
+static size_t rknpu_cap_len;
+static struct proc_dir_entry *rknpu_cap_proc;
+
+static void rknpu_cap_store(struct iommu_domain *dom, u32 tag, u32 iova, u32 len)
+{
+	u8 *dst;
+	u32 off;
+
+	if (!rknpu_cap_buf || !dom || !iova || !len)
+		return;
+	if (rknpu_cap_len + 12 + len > RKNPU_CAP_MAX)
+		return;
+
+	dst = rknpu_cap_buf + rknpu_cap_len;
+	put_unaligned_le32(tag, dst + 0);
+	put_unaligned_le32(iova, dst + 4);
+	put_unaligned_le32(len, dst + 8);
+	dst += 12;
+
+	for (off = 0; off < len; off += PAGE_SIZE) {
+		u32 chunk = min_t(u32, PAGE_SIZE, len - off);
+		phys_addr_t phys = iommu_iova_to_phys(dom, iova + off);
+		const u8 *p = NULL;
+		void __iomem *io = NULL;
+		u32 i;
+
+		if (!phys) {
+			memset(dst + off, 0, chunk);
+			continue;
+		}
+		if (pfn_valid(__phys_to_pfn(phys)))
+			p = (const u8 *)phys_to_virt(phys);
+		else
+			io = ioremap(phys, chunk);
+
+		if (p)
+			memcpy(dst + off, p, chunk);
+		else if (io)
+			for (i = 0; i < chunk; i++)
+				dst[off + i] = readb(io + i);
+		else
+			memset(dst + off, 0, chunk);
+
+		if (io)
+			iounmap(io);
+	}
+
+	rknpu_cap_len += 12 + len;
+}
+
+static ssize_t rknpu_cap_proc_read(struct file *f, char __user *ubuf,
+				   size_t count, loff_t *ppos)
+{
+	return simple_read_from_buffer(ubuf, count, ppos, rknpu_cap_buf,
+				       rknpu_cap_len);
+}
