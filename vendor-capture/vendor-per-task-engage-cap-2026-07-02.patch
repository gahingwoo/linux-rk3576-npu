+/*
+ * CAPTURE: dump the CONTENTS of a BO referenced by the regcmd (weights / input /
+ * bias / output) so the vendor payload can be diffed byte-for-byte against the
+ * mesa ROCKET_DEBUG=dump_bos buffers. The regcmd stores each DMA address as the
+ * full IOVA in one entry's val field; translate it through the job's IOMMU
+ * domain and read the bytes. DRAM-backed BOs go via phys_to_virt; the on-chip
+ * NBUF/CBUF SRAM window is not in the linear map, so it is ioremap'd. Prints
+ * stats (distinct byte values / nonzero count over the window) + a hex head.
+ */
+static void rknpu_cap_dump_bo(struct iommu_domain *dom, const char *name,
+			      u32 iova, u32 len, u32 hexlen)
+{
+	phys_addr_t phys;
+	const u8 *p = NULL;
+	void __iomem *io = NULL;
+	u32 i, distinct = 0, nonzero = 0;
+	u8 seen[256] = { 0 };
+
+	if (!dom || !iova) {
+		pr_info("rknpu cap: BO %-7s iova=0x%08x <no domain/addr>\n",
+			name, iova);
+		return;
+	}
+
+	phys = iommu_iova_to_phys(dom, iova);
+	if (!phys) {
+		pr_info("rknpu cap: BO %-7s iova=0x%08x <iommu unmapped>\n",
+			name, iova);
+		return;
+	}
+
+	if (pfn_valid(__phys_to_pfn(phys)))
+		p = (const u8 *)phys_to_virt(phys);
+	else
+		io = ioremap(phys, len);
+
+	if (!p && !io) {
+		pr_info("rknpu cap: BO %-7s iova=0x%08x phys=0x%llx <map failed>\n",
+			name, iova, (u64)phys);
+		return;
+	}
+
+	for (i = 0; i < len; i++) {
+		u8 b = io ? readb(io + i) : p[i];
+
+		if (b)
+			nonzero++;
+		if (!seen[b]) {
+			seen[b] = 1;
+			distinct++;
+		}
+	}
+
+	pr_info("rknpu cap: BO %-7s iova=0x%08x phys=0x%llx len=%u distinct=%u nonzero=%u\n",
+		name, iova, (u64)phys, len, distinct, nonzero);
+
+	for (i = 0; i < len && i < hexlen; i += 16) {
+		u8 row[16] = { 0 };
+		u32 j;
+
+		for (j = 0; j < 16 && i + j < len; j++)
+			row[j] = io ? readb(io + i + j) : p[i + j];
+
+		pr_info("rknpu cap: BO %-7s +%04x: %16ph\n", name, i, row);
+	}
+
+	if (io)
+		iounmap(io);
+}
