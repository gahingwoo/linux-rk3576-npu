#!/bin/sh
# ---------------------------------------------------------------------------
# RK3576 PINNED-SPREAD (2026-07-16). Falsification test spun out of the vendor
# two-submit trace: the vendor's warm submit re-arms with a register kick BYTE-
# IDENTICAL to the cold one, doing NOTHING between submits (no reset, no CBUF
# reinit, no IOMMU touch) -- so the arming is a cold-start HW latch that PERSISTS
# for the whole power session. Rocket does MORE between submits: it autosuspends
# at 50ms and its runtime_resume runs rocket_core_reset()+rocket_core_pp_state_init()
# +IOMMU attach, which (per rocket_core.c:243) the genpd power-off forces because
# it clears the PP state. HYPOTHESIS: rocket TEARS DOWN the cold-start latch
# between ops; keep ONE continuous power session and op1+ should re-arm.
#
# DELTA vs the (closed) SPREAD-CONFIRM: identical regime + one added step --
# pin power by setting autosuspend_delay_ms huge so the domain never drops
# between the per-op submits (mirrors the vendor's proven warm-session regime).
# Standard pm_runtime sysfs; NO kernel rebuild.
#
#   VERDICT:
#     ops 1+ out_class=REAL + nonzero core_dt_wr  => PIN HELPED: the wall was the
#         autosuspend/reset teardown between submits (rocket-side, fixable).
#     only op 0 REAL (ops 1+ EMPTY/ZEROPOINT)     => PIN DID NOT HELP: not a
#         power/reset teardown -> warm-submit re-arm is silicon-level (RTL wall).
# ---------------------------------------------------------------------------
NPU_DIR=/opt/npu-test
C=/dev/console
MN="$NPU_DIR/mobilenet_v1_1.0_224_quant.tflite"
P=/sys/module/rocket/parameters
log() { echo "$@" > "$C"; }

start() {
	i=0
	while [ ! -c /dev/accel/accel0 ] && [ "$i" -lt 20 ]; do sleep 0.5; i=$((i + 1)); done
	[ -c /dev/accel/accel0 ] || { log "pinned-spread: no accel device"; return 0; }
	dmesg -n 8 2>/dev/null

	# ---- THE DELTA: pin power so all per-op submits share ONE session ----
	# Set autosuspend_delay_ms huge on every rocket NPU device (keep control=auto
	# so the first submit still resumes+arms, then it never suspends again).
	pinned=0
	for f in $(find /sys/devices -path '*power/autosuspend_delay_ms' 2>/dev/null); do
		case "$f" in
		*npu*|*27700000*|*rocket*)
			echo 3600000 > "$f" 2>/dev/null && pinned=$((pinned + 1)) && log "pinned $f -> $(cat "$f")"
			;;
		esac
	done
	[ "$pinned" -gt 0 ] || log "WARN: no autosuspend_delay_ms found under npu -- power NOT pinned"

	# ---- regime: per-op independent single-task submits (IDENTICAL to spread-confirm) ----
	echo 0 > $P/cbuf_reset 2>/dev/null
	echo -1 > $P/enable_mask 2>/dev/null
	echo 1 > $P/perjob_ppinit 2>/dev/null
	echo 0 > $P/bisect 2>/dev/null
	echo 0 > $P/rekick_reset 2>/dev/null
	echo 0 > $P/wg_warm_chain 2>/dev/null
	echo 0 > $P/multitask_poll 2>/dev/null
	echo 0 > $P/wg_continuous 2>/dev/null
	echo 0 > $P/chain_task_number 2>/dev/null
	echo 0 > $P/geom_both 2>/dev/null
	echo 0 > $P/geom_all 2>/dev/null
	echo 0 > $P/conv0_twice 2>/dev/null
	echo 0 > $P/open_high 2>/dev/null
	echo 0 > $P/audit_all 2>/dev/null
	echo 0 > $P/audit_arm 2>/dev/null
	echo 0 > $P/pp_alt 2>/dev/null
	echo -1 > $P/sptr_override 2>/dev/null
	echo 0 > $P/trailer_check 2>/dev/null
	echo 0 > $P/bare_tasknum 2>/dev/null
	echo 0 > $P/read_margin 2>/dev/null
	echo 1 > $P/zero_out_bos 2>/dev/null
	echo 1 > $P/spread_confirm 2>/dev/null

	dmesg -c >/dev/null 2>&1
	log ""
	log "===== PINNED-SPREAD: per-op independent submits, POWER PINNED (one session) ====="
	env TEFLON_LIB=/usr/lib/libteflon.so ROCKET_TILE_JOBS=1 \
		python3 "$NPU_DIR/infer.py" "$MN" > "$C" 2>&1

	# ---- compute verdict from the per-op oracle lines ----
	dmesg 2>/dev/null | grep -aE 'rocket spread op=' > "$NPU_DIR/pinspread.log"
	cat "$NPU_DIR/pinspread.log" > "$C" 2>&1
	# count ops>=1 that are REAL with nonzero dt_wr
	later_real=$(awk '
		/rocket spread op=/ {
			op=-1; dt=0; cls="";
			for (i=1;i<=NF;i++){
				if ($i ~ /^op=/){sub("op=","",$i); op=$i}
				if ($i ~ /^core_dt_wr=/){sub("core_dt_wr=","",$i); dt=$i}
				if ($i ~ /^out_class=/){sub("out_class=","",$i); cls=$i}
			}
			if (op+0>=1 && cls=="REAL" && dt+0>0) c++
		} END{print c+0}' "$NPU_DIR/pinspread.log")
	op0_real=$(grep -ac 'op=0 .*out_class=REAL' "$NPU_DIR/pinspread.log")

	log ""
	log "=========================== VERDICT ==========================="
	if [ "${later_real:-0}" -gt 0 ]; then
		log " VERDICT: PIN HELPED -- $later_real op(s)>=1 are REAL with nonzero dt_wr."
		log "  => the wall WAS the autosuspend/reset teardown between submits (rocket-side, fixable)."
		log "  => keep ONE power session (or skip inter-submit reset) and per-op dispatch re-arms."
	else
		log " VERDICT: PIN DID NOT HELP -- ops>=1 still EMPTY even with power pinned (one session)."
		log "  => not a power/reset teardown. Warm-submit re-arm is silicon-level (RTL wall)."
		log "  (op0 REAL=$op0_real confirms cold-start still works, so the rig is fine.)"
	fi
	log " (read the 'rocket spread op=N .. out_class=.. core_dt_wr=..' lines above; task_count must be 1)"
	log "==============================================================="
	sync
}

case "$1" in
	start) start ;;
	stop|restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
